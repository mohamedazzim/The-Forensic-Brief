---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterCTA from '../../components/NewsletterCTA.astro';
import StructuredData from '../../components/StructuredData.astro';
import { getCollection } from 'astro:content';

const books = await getCollection('books', ({ data }) => data.status === 'published');
const sortedBooks = books.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const isRemoteUrl = (value?: string) => /^https?:\/\//i.test(value || '');

async function isReachable(url?: string) {
  if (!url) return false;
  if (!isRemoteUrl(url)) return true;

  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 5000);

  try {
    const response = await fetch(url, {
      method: 'HEAD',
      signal: controller.signal,
      redirect: 'follow',
    });
    return response.ok;
  } catch {
    return false;
  } finally {
    clearTimeout(timeout);
  }
}

const booksWithAvailability = await Promise.all(
  sortedBooks.map(async (book) => ({
    ...book,
    coverAvailable: await isReachable(book.data.cover),
    pdfAvailable: await isReachable(book.data.pdfUrl),
  }))
);

const galleryBooks =
  booksWithAvailability.length > 0
    ? Array.from({ length: 4 }, (_, index) => booksWithAvailability[index % booksWithAvailability.length])
    : [];
---

<BaseLayout title="Books" description="Free PDF downloads and hardcopy editions of The Forensic Brief series.">
  <StructuredData
    type="collection"
    data={{
      name: 'Books',
      description: 'Free PDF downloads and hardcopy editions of The Forensic Brief series.',
      url: 'https://theforensicbrief.com/books/',
    }}
  />
  <StructuredData
    type="breadcrumb"
    data={{
      items: [
        { name: 'Home', url: '/' },
        { name: 'Books', url: '/books/' },
      ],
    }}
  />
  <section class="content-section">
    <div class="section-header">
      <h1 class="section-title">Books</h1>
      <p class="section-description">Free PDF downloads and hardcopy editions of The Forensic Brief series.</p>
    </div>
    <hr class="section-rule">

    {galleryBooks.length > 0 ? (
      <div class="book-grid">
        {galleryBooks.map((book, index) => (
          <a
            class="book-card"
            href={`/books/${book.id.replace(/\.(md|mdx)$/, '')}/`}
            aria-label={`Open ${book.data.title} book details${index > 0 ? `, copy ${index + 1}` : ''}`}
          >
            <div class="book-cover">
              {book.coverAvailable ? (
                <img
                  src={book.data.cover}
                  alt={`Cover of ${book.data.title}`}
                  width="300"
                  height="450"
                  loading={index === 0 ? 'eager' : 'lazy'}
                />
              ) : (
                <div class="book-cover-fallback" role="img" aria-label={`Cover unavailable for ${book.data.title}`}>
                  <span>Cover unavailable</span>
                </div>
              )}
            </div>
            <h2 class="book-title">{book.data.title}</h2>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty-state">Books coming soon.</p>
    )}
  </section>

  <NewsletterCTA />
</BaseLayout>

<style>
  .content-section {
    margin-bottom: 72px;
  }

  .section-header {
    margin-bottom: 8px;
  }

  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.25;
  }

  .section-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 6px;
    max-width: 560px;
  }

  .section-rule {
    width: 100%;
    height: 1px;
    background: var(--border-light);
    border: none;
    margin: 20px 0 28px;
  }

  .book-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
    align-items: start;
  }

  .book-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    padding: 20px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .book-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(31, 41, 51, 0.08);
  }

  .book-cover {
    width: 100%;
    max-width: 160px;
    width: 100%;
    pointer-events: none;
  }

  .book-cover img {
    width: 100%;
    height: auto;
    display: block;
  }

  .book-cover-fallback {
    width: 100%;
    min-height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    text-align: center;
    background: var(--bg);
    border: 1px solid var(--border-light);
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .book-title {
    font-size: 1rem;
    text-align: center;
    color: var(--text-primary);
  }

  .empty-state {
    text-align: center;
    padding: 60px 0;
    color: var(--text-muted);
    font-style: italic;
  }

  @media (max-width: 600px) {
    .book-grid {
      gap: 16px;
    }

    .book-card {
      padding: 14px;
    }

    .book-cover {
      max-width: 120px;
    }

    .book-cover-fallback {
      min-height: 180px;
    }
  }
</style>

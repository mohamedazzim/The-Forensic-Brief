---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import NewsletterCTA from '../../components/NewsletterCTA.astro';
import StructuredData from '../../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { sortNewestFirst } from '../../utils/contentEntries';

const essays = await getCollection('essays', ({ data }) => data.status === 'published');
const sortedEssays = sortNewestFirst(essays);
const formatDate = (date?: Date, label?: string) => label || (date ? date.toISOString().split('T')[0] : '');

const seriesOptions = [
  { id: 'human-in-control', label: 'Human in Control' },
  { id: 'out-of-bounds', label: 'Out of Bounds' },
  { id: 'accountable-autonomy', label: 'Accountable Autonomy' },
  { id: 'six-dimensions', label: 'The Six Dimensions' },
  { id: 'the-burden', label: 'The Burden' },
];

const currentSeries = Astro.url.searchParams.get('series') ?? '';

const filteredEssays = sortedEssays.filter((e) => e.data.category === 'essay');
const filteredPatterns = sortedEssays.filter((e) => e.data.category === 'pattern');
---

<BaseLayout title="Essays">
  <StructuredData
    type="collection"
    data={{
      name: 'Essays',
      url: 'https://theforensicbrief.com/essays/',
    }}
  />
  <StructuredData
    type="breadcrumb"
    data={{
      items: [
        { name: 'Home', url: '/' },
        { name: 'Essays', url: '/essays/' },
      ],
    }}
  />
  <section class="content-section">
    <div class="section-header">
      <h1 class="section-title">Essays</h1>
    </div>
    <hr class="section-rule">

    <div class="series-filter">
      <label for="series-filter" class="series-filter-label">Series</label>
      <select id="series-filter" name="series" class="series-filter-select">
        <option value="" selected={!currentSeries}>All</option>
        {seriesOptions.map((option) => (
          <option value={option.id} selected={currentSeries === option.id}>{option.label}</option>
        ))}
      </select>
    </div>

    {filteredEssays.length > 0 ? (
      <div class="card-grid" data-essay-grid>
        {filteredEssays.map((essay) => (
          <Card
            title={essay.data.title}
            excerpt={essay.data.summary}
            date={formatDate(essay.data.date, essay.data.dateLabel)}
            category={essay.data.series || 'Essay'}
            href={`/essays/${essay.id.replace(/\.(md|mdx)$/, '')}/`}
            linkText="Read essay"
            dataSeries={essay.data.series || ''}
            dataCategory="essay"
          />
        ))}
      </div>
    ) : (
      <p class="empty-state">No essays published yet.</p>
    )}
  </section>

  {filteredPatterns.length > 0 && (
    <section class="content-section" data-pattern-section>
      <div class="section-header">
        <h2 class="section-title">Patterns</h2>
      </div>
      <hr class="section-rule">

      <div class="card-grid" data-pattern-grid>
        {filteredPatterns.map((pattern) => (
          <Card
            title={pattern.data.title}
            excerpt={pattern.data.summary}
            date={formatDate(pattern.data.date, pattern.data.dateLabel)}
            category={pattern.data.patternId || 'Pattern'}
            href={`/essays/${pattern.id.replace(/\.(md|mdx)$/, '')}/`}
            linkText="View pattern"
            dataSeries={pattern.data.series || ''}
            dataCategory="pattern"
          />
        ))}
      </div>
    </section>
  )}

  <p class="empty-state" hidden>No essays match this filter.</p>

  <NewsletterCTA />
</BaseLayout>

<script is:inline>
  const select = document.getElementById('series-filter');
  const cards = [...document.querySelectorAll('.article-card')];
  const empty = document.querySelector('.empty-state');
  const patternSection = document.querySelector('[data-pattern-section]');

  const applySeriesFilter = (series) => {
    let shown = 0;
    let shownPatterns = 0;

    cards.forEach((card) => {
      const isMatch = !series || card.getAttribute('data-series') === series;
      card.hidden = !isMatch;

      if (isMatch) {
        shown += 1;
        if (card.getAttribute('data-category') === 'pattern') shownPatterns += 1;
      }
    });

    if (empty) empty.hidden = shown > 0;
    if (patternSection) patternSection.hidden = shownPatterns === 0;
  };

  const params = new URLSearchParams(window.location.search);
  const currentSeries = params.get('series') || '';
  if (select instanceof HTMLSelectElement) {
    select.value = currentSeries;
    select.addEventListener('change', () => {
      const nextUrl = new URL(window.location.href);
      if (select.value) nextUrl.searchParams.set('series', select.value);
      else nextUrl.searchParams.delete('series');
      window.location.assign(nextUrl.toString());
    });
  }

  applySeriesFilter(currentSeries);
</script>

<style>
  .content-section {
    margin-bottom: 72px;
  }

  .section-header {
    margin-bottom: 8px;
  }

  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.25;
  }

  .section-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 6px;
    max-width: 560px;
  }

  .section-rule {
    width: 100%;
    height: 1px;
    background: var(--border-light);
    border: none;
    margin: 20px 0 28px;
  }

  .series-filter {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 24px;
  }

  .series-filter-label {
    font-size: var(--text-sm);
    color: var(--text-light);
    font-weight: 500;
  }

  .series-filter-select {
    min-width: 240px;
    max-width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text-primary);
    font-size: var(--text-sm);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .empty-state {
    color: var(--text-muted);
    font-style: italic;
    text-align: center;
    padding: 40px 0;
  }

  @media (max-width: 600px) {
    .series-filter-select {
      width: 100%;
      min-width: 0;
    }
  }
</style>

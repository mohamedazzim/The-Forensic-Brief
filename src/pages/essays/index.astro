---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import FilterBar from '../../components/FilterBar.astro';
import { getCollection } from 'astro:content';

const essays = await getCollection('essays', ({ data }) => data.status === 'published');
const sortedEssays = essays.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const seriesOptions = [
  { id: 'human-in-control', label: 'Human in Control' },
  { id: 'out-of-bounds', label: 'Out of Bounds' },
  { id: 'accountable-autonomy', label: 'Accountable Autonomy' },
  { id: 'six-dimensions', label: 'The Six Dimensions' },
  { id: 'the-burden', label: 'The Burden' },
];

const categoryOptions = [
  { id: 'essay', label: 'Essays' },
  { id: 'pattern', label: 'Patterns' },
];

const filteredEssays = sortedEssays.filter(e => e.data.category === 'essay');
const filteredPatterns = sortedEssays.filter(e => e.data.category === 'pattern');
---

<BaseLayout title="Essays" description="Long-form analysis of AI failure patterns, governance frameworks, and accountability structures.">
  <section class="content-section">
    <div class="section-header">
      <h1 class="section-title">Essays</h1>
      <p class="section-description">Long-form analysis of AI failure patterns, governance frameworks, and accountability structures.</p>
    </div>
    <hr class="section-rule">

    <FilterBar 
      label="Series" 
      options={seriesOptions}
      baseUrl="/essays/"
    />

    <FilterBar 
      label="Category" 
      options={categoryOptions}
      baseUrl="/essays/"
    />

    {filteredEssays.length > 0 ? (
      <div class="card-grid">
        {filteredEssays.map((essay) => (
          <Card
            title={essay.data.title}
            excerpt={essay.data.summary}
            date={essay.data.date.toISOString().split('T')[0]}
            category={essay.data.series || 'Essay'}
            href={`/essays/${essay.id.replace(/\.(md|mdx)$/, '')}/`}
            linkText="Read essay"
          />
        ))}
      </div>
    ) : (
      <p class="empty-state">No essays published yet.</p>
    )}
  </section>

  {filteredPatterns.length > 0 && (
    <section class="content-section">
      <div class="section-header">
        <h2 class="section-title">Patterns</h2>
        <p class="section-description">Structured failure-signature analyses extracted from incident data.</p>
      </div>
      <hr class="section-rule">

      <div class="card-grid">
        {filteredPatterns.map((pattern) => (
          <Card
            title={pattern.data.title}
            excerpt={pattern.data.summary}
            date={pattern.data.date.toISOString().split('T')[0]}
            category={pattern.data.patternId || 'Pattern'}
            href={`/essays/${pattern.id.replace(/\.(md|mdx)$/, '')}/`}
            linkText="View pattern"
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .content-section {
    margin-bottom: 72px;
  }

  .section-header {
    margin-bottom: 8px;
  }

  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.25;
  }

  .section-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 6px;
    max-width: 560px;
  }

  .section-rule {
    width: 100%;
    height: 1px;
    background: var(--border-light);
    border: none;
    margin: 20px 0 28px;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .empty-state {
    color: var(--text-muted);
    font-style: italic;
    text-align: center;
    padding: 40px 0;
  }
</style>

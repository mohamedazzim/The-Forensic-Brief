---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Card from '../../../components/Card.astro';
import StructuredData from '../../../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { entrySlug, formatEntryDate, resolveSortDate } from '../../../utils/contentEntries';

export async function getStaticPaths() {
  const essays = await getCollection('essays', ({ data }) => data.status === 'published');
  const seriesNames = [...new Set(
    essays
      .filter((essay) => essay.data.category === 'essay' && essay.data.series)
      .map((essay) => essay.data.series)
  )].sort((a, b) => a.localeCompare(b));

  return seriesNames.map((series) => {
    const items = essays.filter((essay) => essay.data.series === series);
    return {
      params: { series },
      props: { series, items },
    };
  });
}

const { series, items } = Astro.props;
const sortedItems = items.sort((a, b) => (a.data.seriesNo ?? 0) - (b.data.seriesNo ?? 0));
---

<BaseLayout title={`Series: ${series}`} description={`Essays in the ${series} series.`}>
  <StructuredData
    type="collection"
    data={{
      name: `Series: ${series}`,
      description: `Essays in the ${series} series.`,
      url: `https://theforensicbrief.com/essays/${series}/`,
    }}
  />
  <StructuredData
    type="breadcrumb"
    data={{
      items: [
        { name: 'Home', url: '/' },
        { name: 'Essays', url: '/essays/' },
        { name: series, url: `/essays/${series}/` },
      ],
    }}
  />
  <section class="content-section">
    <div class="section-header">
      <span class="eyebrow">Essay Series</span>
      <h1 class="section-title">{series}</h1>
      <p class="section-description">{sortedItems.length} essay{sortedItems.length === 1 ? '' : 's'} in this series.</p>
    </div>
    <hr class="section-rule">

    {sortedItems.length > 0 ? (
      <div class="card-grid">
        {sortedItems.map((essay) => (
          <Card
            title={essay.data.title}
            excerpt={essay.data.excerpt || essay.data.summary}
            date={formatEntryDate(essay.data)}
            dateTime={resolveSortDate(essay.data)?.toISOString()}
            category={essay.data.category === 'pattern' ? 'Pattern' : 'Essay'}
            href={`/essays/${entrySlug(essay)}/`}
            linkText="Read more"
          />
        ))}
      </div>
    ) : (
      <p class="empty-state">No published essays in this series yet.</p>
    )}
  </section>
</BaseLayout>

<style>
  .content-section {
    margin-bottom: 72px;
  }

  .section-header {
    margin-bottom: 8px;
  }

  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.25;
    margin-top: 8px;
  }

  .section-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 6px;
    max-width: 560px;
  }

  .section-rule {
    width: 100%;
    height: 1px;
    background: var(--border-light);
    border: none;
    margin: 20px 0 28px;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .empty-state {
    color: var(--text-muted);
    font-style: italic;
  }
</style>

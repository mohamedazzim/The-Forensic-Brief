---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Card from '../../../components/Card.astro';
import StructuredData from '../../../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { entrySlug } from '../../../utils/contentEntries';
import { sortNewestFirst } from '../../../utils/contentEntries';

const essays = await getCollection('essays', ({ data }) => data.status === 'published' && data.category === 'pattern');
const sortedEssays = sortNewestFirst(essays);
const formatDate = (date?: Date, label?: string) => label || (date ? date.toISOString().split('T')[0] : '');
---

<BaseLayout title="Patterns" description="Structured failure-signature analyses extracted from incident data.">
  <StructuredData
    type="collection"
    data={{
      name: 'Patterns',
      description: 'Structured failure-signature analyses extracted from incident data.',
      url: 'https://theforensicbrief.com/essays/patterns/',
    }}
  />
  <StructuredData
    type="breadcrumb"
    data={{
      items: [
        { name: 'Home', url: '/' },
        { name: 'Essays', url: '/essays/' },
        { name: 'Patterns', url: '/essays/patterns/' },
      ],
    }}
  />
  <section class="content-section">
    <div class="section-header">
      <h1 class="section-title">Patterns</h1>
    </div>
    <hr class="section-rule">

    {sortedEssays.length > 0 ? (
      <div class="card-grid">
        {sortedEssays.map((pattern) => (
          <Card
            title={pattern.data.title}
            excerpt={pattern.data.excerpt || pattern.data.summary}
            date={formatDate(pattern.data.date, pattern.data.dateLabel)}
            category={pattern.data.patternId || 'Pattern'}
            href={`/essays/${entrySlug(pattern)}/`}
            linkText="View pattern"
          />
        ))}
      </div>
    ) : (
      <p class="empty-state">No patterns published yet.</p>
    )}
  </section>
</BaseLayout>

<style>
  .content-section {
    margin-bottom: 72px;
  }

  .section-header {
    margin-bottom: 8px;
  }

  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.25;
  }

  .section-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 6px;
    max-width: 560px;
  }

  .section-rule {
    width: 100%;
    height: 1px;
    background: var(--border-light);
    border: none;
    margin: 20px 0 28px;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .empty-state {
    color: var(--text-muted);
    font-style: italic;
    text-align: center;
    padding: 40px 0;
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import StructuredData from '../../components/StructuredData.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allContent = [
    ...(await getCollection('incidents', ({ data }) => data.status === 'published')),
    ...(await getCollection('essays', ({ data }) => data.status === 'published')),
    ...(await getCollection('observations', ({ data }) => data.status === 'published')),
    ...(await getCollection('artifacts', ({ data }) => data.status === 'published')),
  ];

  const tagMap: Record<string, typeof allContent> = {};
  allContent.forEach((item) => {
    if (item.data.tags) {
      item.data.tags.forEach((tag) => {
        if (!tagMap[tag]) tagMap[tag] = [];
        tagMap[tag].push(item);
      });
    }
  });

  const tags = ['red-teaming', 'human-oversight', 'eu-ai-act', 'automation-bias', 'dpdp', 'provenance', 'agentic-ai', 'audit-trail', 'llm-security', 'ai-governance', 'mris', 'risk-disclosure', 'checklist', 'deployment', 'governance', 'customer-service', 'liability', 'chatbot', 'attention-mechanisms', 'prompt-injection', 'decision-making', 'audit', 'topic-slug'];
  return tags.map((tag) => ({
    params: { tag },
    props: { tag, items: tagMap[tag] || [] },
  }));
}

const { tag, items } = Astro.props;
const sortedItems = items.sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0));
const formatDate = (date?: Date, label?: string) => label || (date ? date.toISOString().split('T')[0] : '');

function getCollectionType(item: any) {
  if (item.collection === 'incidents') return 'Incident';
  if (item.collection === 'essays') {
    if (item.data.category === 'pattern') return 'Pattern';
    return 'Essay';
  }
  if (item.collection === 'observations') return 'Observation';
  if (item.collection === 'artifacts') return 'Artifact';
  return 'Content';
}

function getHref(item: any) {
  const cleanId = item.id.replace(/\.(md|mdx)$/, '');
  if (item.collection === 'incidents') return `/incidents/${cleanId}/`;
  if (item.collection === 'essays') return `/essays/${cleanId}/`;
  if (item.collection === 'observations') return `/observations/${cleanId}/`;
  if (item.collection === 'artifacts') return `/artifacts/${cleanId}/`;
  return '#';
}
---

<BaseLayout title={`Topic: ${tag}`} description={`All content tagged with "${tag}".`}>
  <StructuredData
    type="collection"
    data={{
      name: `Topic: ${tag}`,
      description: `All content tagged with "${tag}".`,
      url: `https://theforensicbrief.com/topics/${tag}/`,
    }}
  />
  <StructuredData
    type="breadcrumb"
    data={{
      items: [
        { name: 'Home', url: '/' },
        { name: 'Topics', url: '/topics/' },
        { name: tag, url: `/topics/${tag}/` },
      ],
    }}
  />
  <section class="content-section">
    <div class="section-header">
      <span class="eyebrow">Topic</span>
      <h1 class="section-title">{tag}</h1>
      <p class="section-description">{sortedItems.length} {sortedItems.length === 1 ? 'item' : 'items'} tagged with "{tag}".</p>
    </div>
    <hr class="section-rule">

    {sortedItems.length > 0 ? (
      <div class="card-grid">
        {sortedItems.map((item) => (
          <Card
            title={item.data.title}
            excerpt={item.data.summary}
            date={formatDate(item.data.date, item.data.dateLabel)}
            category={getCollectionType(item)}
            href={getHref(item)}
            linkText="Read more"
          />
        ))}
      </div>
    ) : (
      <p class="empty-state">No published content is tagged with this topic yet.</p>
    )}
  </section>
</BaseLayout>

<style>
  .content-section {
    margin-bottom: 72px;
  }

  .section-header {
    margin-bottom: 8px;
  }

  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.25;
    margin-top: 8px;
  }

  .section-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 6px;
    max-width: 560px;
  }

  .section-rule {
    width: 100%;
    height: 1px;
    background: var(--border-light);
    border: none;
    margin: 20px 0 28px;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .empty-state {
    color: var(--text-muted);
    font-style: italic;
  }
</style>

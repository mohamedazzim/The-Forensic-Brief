---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StructuredData from '../../components/StructuredData.astro';
import { getCollection } from 'astro:content';

const allContent = [
  ...(await getCollection('incidents')),
  ...(await getCollection('essays')),
  ...(await getCollection('observations')),
  ...(await getCollection('artifacts')),
];

const tagCounts: Record<string, number> = {};
allContent.forEach((item) => {
  if (item.data.tags) {
    item.data.tags.forEach((tag) => {
      tagCounts[tag] = (tagCounts[tag] || 0) + 1;
    });
  }
});

const sortedTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Topics" description="Browse content by topic.">
  <StructuredData
    type="collection"
    data={{
      name: 'Topics',
      description: 'Browse all content by topic.',
      url: 'https://theforensicbrief.com/topics/',
    }}
  />
  <StructuredData
    type="breadcrumb"
    data={{
      items: [
        { name: 'Home', url: '/' },
        { name: 'Topics', url: '/topics/' },
      ],
    }}
  />
  <section class="content-section">
    <div class="section-header">
      <h1 class="section-title">Topics</h1>
      <p class="section-description">Browse all content by topic.</p>
    </div>
    <hr class="section-rule">

    {sortedTags.length > 0 ? (
      <div class="tag-grid">
        {sortedTags.map(([tag, count]) => (
          <a href={`/topics/${tag}/`} class="tag-item">
            <span class="tag-name">{tag}</span>
            <span class="tag-count">{count} {count === 1 ? 'item' : 'items'}</span>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty-state">No topics found.</p>
    )}
  </section>
</BaseLayout>

<style>
  .content-section {
    margin-bottom: 72px;
  }

  .section-header {
    margin-bottom: 8px;
  }

  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.25;
  }

  .section-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 6px;
    max-width: 560px;
  }

  .section-rule {
    width: 100%;
    height: 1px;
    background: var(--border-light);
    border: none;
    margin: 20px 0 28px;
  }

  .tag-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
  }

  .tag-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }

  .tag-item:hover {
    background: var(--text-primary);
    border-color: var(--text-primary);
  }

  .tag-item:hover .tag-name,
  .tag-item:hover .tag-count {
    color: var(--bg);
  }

  .tag-name {
    font-size: var(--text-sm);
    color: var(--text-primary);
    font-weight: 500;
  }

  .tag-count {
    font-size: var(--text-xs);
    color: var(--text-light);
  }

  .empty-state {
    text-align: center;
    padding: 60px 0;
    color: var(--text-muted);
    font-style: italic;
  }
</style>

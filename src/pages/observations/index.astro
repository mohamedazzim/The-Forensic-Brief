---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import NewsletterCTA from '../../components/NewsletterCTA.astro';
import StructuredData from '../../components/StructuredData.astro';
import { getCollection } from 'astro:content';

const observations = await getCollection('observations', ({ data }) => data.status === 'published');
const sortedObservations = observations.sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0));
const formatDate = (date?: Date, label?: string) => label || (date ? date.toISOString().split('T')[0] : '');
---

<BaseLayout title="Observations">
  <StructuredData
    type="collection"
    data={{
      name: 'Observations',
      url: 'https://theforensicbrief.com/observations/',
    }}
  />
  <StructuredData
    type="breadcrumb"
    data={{
      items: [
        { name: 'Home', url: '/' },
        { name: 'Observations', url: '/observations/' },
      ],
    }}
  />
  <section class="content-section">
    <div class="section-header">
      <h1 class="section-title">Observations</h1>
    </div>
    <hr class="section-rule">

    {sortedObservations.length > 0 ? (
      <div class="card-grid">
        {sortedObservations.map((observation) => (
          <Card
            title={observation.data.title}
            excerpt={observation.data.summary}
            date={formatDate(observation.data.date, observation.data.dateLabel)}
            category={observation.data.observationStatus || 'Observation'}
            href={`/observations/${observation.id.replace(/\.(md|mdx)$/, '')}/`}
            linkText="Read observation"
          />
        ))}
      </div>
    ) : (
      <p class="empty-state">No observations published yet.</p>
    )}
  </section>

  <NewsletterCTA />
</BaseLayout>

<style>
  .content-section {
    margin-bottom: 72px;
  }

  .section-header {
    margin-bottom: 8px;
  }

  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.25;
  }

  .section-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 6px;
    max-width: 560px;
  }

  .section-rule {
    width: 100%;
    height: 1px;
    background: var(--border-light);
    border: none;
    margin: 20px 0 28px;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .empty-state {
    text-align: center;
    padding: 60px 0;
    color: var(--text-muted);
    font-style: italic;
  }
</style>

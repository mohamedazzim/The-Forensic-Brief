---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterCTA from '../../components/NewsletterCTA.astro';
import StructuredData from '../../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { entrySlug, sortNewestFirst } from '../../utils/contentEntries';

const artifacts = await getCollection('artifacts', ({ data }) => data.status === 'published');
const sortedArtifacts = sortNewestFirst(artifacts);
---

<BaseLayout title="Artifacts">
  <StructuredData
    type="collection"
    data={{
      name: 'Artifacts',
      url: 'https://theforensicbrief.com/artifacts/',
    }}
  />
  <StructuredData
    type="breadcrumb"
    data={{
      items: [
        { name: 'Home', url: '/' },
        { name: 'Artifacts', url: '/artifacts/' },
      ],
    }}
  />
  <section class="content-section">
    <div class="section-header">
      <h1 class="section-title">Artifacts</h1>
    </div>
    <hr class="section-rule">

    {sortedArtifacts.length > 0 ? (
      <div class="artifact-grid">
        {sortedArtifacts.map((artifact) => (
          <article class="artifact-card">
            <div class="artifact-header">
              <span class="artifact-type">{artifact.data.artifactType}</span>
              <span class="artifact-version">v{artifact.data.version}</span>
            </div>
            <h2 class="artifact-title">
              <a href={`/artifacts/${entrySlug(artifact)}/`}>{artifact.data.title}</a>
            </h2>
            {(artifact.data.excerpt || artifact.data.summary) && <p class="artifact-summary">{artifact.data.excerpt || artifact.data.summary}</p>}
            <a href={`/artifacts/${entrySlug(artifact)}/`} class="artifact-link">
              View artifact ->
            </a>
          </article>
        ))}
      </div>
    ) : (
      <p class="empty-state">No artifacts published yet.</p>
    )}
  </section>

  <NewsletterCTA />
</BaseLayout>

<style>
  .content-section {
    margin-bottom: 72px;
  }

  .section-header {
    margin-bottom: 8px;
  }

  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.25;
  }

  .section-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 6px;
    max-width: 560px;
  }

  .section-rule {
    width: 100%;
    height: 1px;
    background: var(--border-light);
    border: none;
    margin: 20px 0 28px;
  }

  .artifact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .artifact-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    padding: 24px;
    display: flex;
    flex-direction: column;
  }

  .artifact-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .artifact-type {
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-light);
  }

  .artifact-version {
    font-size: var(--text-xs);
    color: var(--text-light);
  }

  .artifact-title {
    font-size: var(--text-lg);
    margin-bottom: 8px;
  }

  .artifact-title a {
    color: inherit;
    text-decoration: none;
    border: none;
  }

  .artifact-title a:hover {
    color: var(--text-muted);
  }

  .artifact-summary {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 16px;
    flex: 1;
  }

  .artifact-link {
    font-size: var(--text-sm);
    color: var(--text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1px;
    align-self: flex-start;
    transition: color 0.2s, border-color 0.2s;
  }

  .artifact-link:hover {
    color: var(--text-muted);
    border-color: var(--text-muted);
  }

  .empty-state {
    text-align: center;
    padding: 60px 0;
    color: var(--text-muted);
    font-style: italic;
  }
</style>

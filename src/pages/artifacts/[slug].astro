---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StructuredData from '../../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { hasContentFiles } from '../../utils/hasContentFiles';
import { entrySlug } from '../../utils/contentEntries';

const essays = await getCollection('essays', ({ data }) => data.status === 'published');
let books = [];
if (hasContentFiles('books')) {
  books = await getCollection('books');
}

export async function getStaticPaths() {
  const artifacts = await getCollection('artifacts', ({ data }) => data.status === 'published');
  return artifacts.map((artifact) => ({
    params: { slug: entrySlug(artifact) },
    props: { artifact },
  }));
}

const { artifact } = Astro.props;
const artifactBodyModules = import.meta.glob('../../content/artifacts/*-content.mdx');
const artifactBodyPath = artifact.data.contentFile
  ? `../../content/artifacts/${artifact.data.contentFile}`
  : '';
const artifactBodyModule = artifactBodyPath && artifactBodyModules[artifactBodyPath]
  ? await artifactBodyModules[artifactBodyPath]()
  : null;
const Content = artifactBodyModule?.default;
const artifactDateDisplay = artifact.data.dateLabel || (artifact.data.date ? artifact.data.date.toISOString().split('T')[0] : '');
const relatedBook = artifact.data.relatedBook
  ? books.find((b) => entrySlug(b) === artifact.data.relatedBook)
  : null;
const artifactUrl = `/artifacts/${entrySlug(artifact)}/`;

const isRemoteUrl = (value?: string) => /^https?:\/\//i.test(value || '');

async function isReachable(url?: string) {
  if (!url) return false;
  if (!isRemoteUrl(url)) return true;

  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 5000);

  try {
    const response = await fetch(url, {
      method: 'HEAD',
      signal: controller.signal,
      redirect: 'follow',
    });
    return response.ok;
  } catch {
    return false;
  } finally {
    clearTimeout(timeout);
  }
}

const downloadAvailability = await Promise.all(
  artifact.data.downloads.map(async (download) => ({
    ...download,
    available: await isReachable(download.url),
  }))
);
---

<BaseLayout title={artifact.data.title} description={artifact.data.summary}>
  <StructuredData
    type="creativework"
    data={{
      name: artifact.data.title,
      description: artifact.data.summary,
      url: artifactUrl,
      license: artifact.data.license,
    }}
  />
  <StructuredData
    type="breadcrumb"
    data={{
      items: [
        { name: 'Home', url: '/' },
        { name: 'Artifacts', url: '/artifacts/' },
        { name: artifact.data.title, url: artifactUrl },
      ],
    }}
  />
  <article class="artifact-page">
    <header class="artifact-header">
      <div class="artifact-meta-top">
        <span class="eyebrow">{artifact.data.artifactType}</span>
        <span class="artifact-version">Version {artifact.data.version}</span>
      </div>
      <h1 class="artifact-title">{artifact.data.title}</h1>
      {artifact.data.summary && <p class="artifact-summary">{artifact.data.summary}</p>}
      {artifactDateDisplay && (
        <p class="artifact-updated">Published {artifactDateDisplay}</p>
      )}
      {artifact.data.updated && (
        <p class="artifact-updated">Last updated {artifact.data.updated.toISOString().split('T')[0]}</p>
      )}

      <div class="artifact-downloads">
        <span class="downloads-label">Download:</span>
        {downloadAvailability.some((download) => download.available) ? (
          downloadAvailability.map((download) => (
            download.available ? (
              <a
                href={download.url}
                class="download-btn"
                target="_blank"
                rel="noopener noreferrer"
              >
                {download.format} ({download.sizeKB} KB)
              </a>
            ) : (
              <span class="download-btn download-btn--disabled" aria-disabled="true">
                {download.format} unavailable ({download.sizeKB} KB)
              </span>
            )
          ))
        ) : (
          <span class="downloads-unavailable">Downloads unavailable</span>
        )}
      </div>

      <div class="artifact-license">
        <span class="license-badge">{artifact.data.license}</span>
      </div>
    </header>

    <div class="artifact-content article-body">
      {Content && <Content />}
    </div>

    {artifact.data.relatedEssays.length > 0 && (
      <section class="related-section">
        <h2>Related Essays</h2>
        <ul>
          {artifact.data.relatedEssays.map((slug) => {
            const essay = essays.find((e) => entrySlug(e) === slug);
            return essay ? (
              <li><a href={`/essays/${slug}/`}>{essay.data.title}</a></li>
            ) : null;
          })}
        </ul>
      </section>
    )}

    {relatedBook && (
      <section class="related-section">
        <h2>Related Book</h2>
        <p><a href={`/books/${artifact.data.relatedBook}/`}>
          {relatedBook.data.title}
        </a></p>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .artifact-page {
    max-width: var(--measure);
  }

  .artifact-header {
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border-light);
  }

  .artifact-meta-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .artifact-version {
    font-size: var(--text-sm);
    color: var(--text-light);
  }

  .artifact-title {
    font-size: var(--text-3xl);
    margin-bottom: 16px;
  }

  .artifact-summary {
    font-size: var(--text-md);
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 24px;
  }

  .artifact-updated {
    font-size: var(--text-sm);
    color: var(--text-light);
    margin-bottom: 16px;
  }

  .artifact-downloads {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .downloads-label {
    font-size: var(--text-sm);
    color: var(--text-light);
    font-weight: 500;
  }

  .download-btn {
    display: inline-block;
    padding: 8px 16px;
    background: var(--text-primary);
    color: var(--bg);
    font-size: var(--text-sm);
    text-decoration: none;
    border: none;
    transition: opacity 0.2s;
  }

  .download-btn:hover {
    opacity: 0.9;
  }

  .download-btn--disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .downloads-unavailable {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .artifact-license {
    margin-top: 16px;
  }

  .license-badge {
    display: inline-block;
    padding: 4px 12px;
    font-size: var(--text-xs);
    background: var(--bg);
    border: 1px solid var(--border-light);
    color: var(--text-light);
  }

  .artifact-content {
    margin-top: 48px;
  }

  .related-section {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--border-light);
  }

  .related-section h2 {
    font-size: var(--text-lg);
    margin-bottom: 12px;
  }

  .related-section ul {
    list-style: none;
  }

  .related-section li {
    margin-bottom: 8px;
  }
</style>

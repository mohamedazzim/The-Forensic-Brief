---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import FilterBar from '../../components/FilterBar.astro';
import { getCollection } from 'astro:content';

const incidents = await getCollection('incidents', ({ data }) => data.status === 'published');

const severityOptions = [
  { id: 'critical', label: 'Critical' },
  { id: 'high', label: 'High' },
  { id: 'moderate', label: 'Moderate' },
  { id: 'low', label: 'Low' },
];

const domainOptions = [
  { id: 'customer-service', label: 'Customer Service' },
  { id: 'lending', label: 'Lending' },
  { id: 'healthcare', label: 'Healthcare' },
];

// Extract unique vendors from incidents
const allVendors = incidents.flatMap(incident => incident.data.systems);
const uniqueVendors = [...new Set(allVendors)];
const vendorOptions = uniqueVendors.map(vendor => ({
  id: vendor.toLowerCase().replace(/\s+/g, '-'),
  label: vendor,
}));

// Get current filter from URL params (simulated for static build)
// In production, use client-side JS or URL params
const sortedIncidents = incidents.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Incidents" description="Documented AI failure events with evidence-based post-mortems and structured timelines.">
  <section class="content-section">
    <div class="section-header">
      <h1 class="section-title">Incidents</h1>
      <p class="section-description">Documented AI failure events with evidence-based post-mortems and structured timelines.</p>
    </div>
    <hr class="section-rule">

    <FilterBar 
      label="Severity" 
      options={severityOptions}
      baseUrl="/incidents/"
    />

    <FilterBar 
      label="Domain" 
      options={domainOptions}
      baseUrl="/incidents/"
    />

    <FilterBar 
      label="Vendor" 
      options={vendorOptions}
      baseUrl="/incidents/"
    />

    {sortedIncidents.length > 0 ? (
      <div class="card-grid">
        {sortedIncidents.map((incident) => (
          <Card
            title={incident.data.title}
            excerpt={incident.data.summary}
            date={incident.data.incidentDate.toISOString().split('T')[0]}
            category={`${incident.data.severity.toUpperCase()} · ${incident.data.domain}`}
            href={`/incidents/${incident.id.replace(/\.(md|mdx)$/, '')}/`}
            linkText="Read report"
            dataSeverity={incident.data.severity}
            dataDomain={incident.data.domain.toLowerCase().replace(/\s+/g, '-')}
            dataVendor={incident.data.systems.join(' ').toLowerCase().replace(/\s+/g, '-')}
          />
        ))}
      </div>
    ) : (
      <p class="empty-state">No incidents published yet.</p>
    )}
  </section>
</BaseLayout>

<script is:inline>
  const params = new URLSearchParams(window.location.search);
  const filters = { severity: params.get('severity'), domain: params.get('domain'), vendor: params.get('vendor') };
  let shown = 0;
  document.querySelectorAll('.article-card').forEach((card) => {
    const match = (!filters.severity || card.getAttribute('data-severity') === filters.severity)
      && (!filters.domain || card.getAttribute('data-domain') === filters.domain)
      && (!filters.vendor || (card.getAttribute('data-vendor') || '').includes(filters.vendor));
    card.hidden = !match;
    if (match) shown += 1;
  });
  const empty = document.querySelector('.empty-state');
  if (empty) empty.hidden = shown > 0;
</script>

<style>
  .content-section {
    margin-bottom: 72px;
  }

  .section-header {
    margin-bottom: 8px;
  }

  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.25;
  }

  .section-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 6px;
    max-width: 560px;
  }

  .section-rule {
    width: 100%;
    height: 1px;
    background: var(--border-light);
    border: none;
    margin: 20px 0 28px;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .empty-state {
    color: var(--text-muted);
    font-style: italic;
    text-align: center;
    padding: 40px 0;
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import NewsletterCTA from '../../components/NewsletterCTA.astro';
import StructuredData from '../../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { entrySlug, sortNewestFirst } from '../../utils/contentEntries';

const incidents = await getCollection('incidents', ({ data }) => data.status === 'published');
const sortedIncidents = sortNewestFirst(incidents);
const formatDate = (date?: Date, label?: string) => label || (date ? date.toISOString().split('T')[0] : '');
---

<BaseLayout title="Incidents">
  <StructuredData
    type="collection"
    data={{
      name: 'Incidents',
      url: 'https://theforensicbrief.com/incidents/',
    }}
  />
  <StructuredData
    type="breadcrumb"
    data={{
      items: [
        { name: 'Home', url: '/' },
        { name: 'Incidents', url: '/incidents/' },
      ],
    }}
  />
  <section class="content-section">
    <div class="section-header">
      <h1 class="section-title">Incidents</h1>
    </div>
    <hr class="section-rule">

    {sortedIncidents.length > 0 ? (
      <div class="card-grid">
        {sortedIncidents.map((incident) => (
          <Card
            title={incident.data.title}
            excerpt={incident.data.summary}
            date={formatDate(incident.data.incidentDate, incident.data.incidentDateLabel)}
            category={`${incident.data.severity?.toUpperCase() || 'INCIDENT'}${incident.data.domain ? ` - ${incident.data.domain}` : ''}`}
            href={`/incidents/${entrySlug(incident)}/`}
            linkText="Read report"
          />
        ))}
      </div>
    ) : (
      <p class="empty-state">No incidents published yet.</p>
    )}
  </section>

  <NewsletterCTA />
</BaseLayout>

<style>
  .content-section {
    margin-bottom: 72px;
  }

  .section-header {
    margin-bottom: 8px;
  }

  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.25;
  }

  .section-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 6px;
    max-width: 560px;
  }

  .section-rule {
    width: 100%;
    height: 1px;
    background: var(--border-light);
    border: none;
    margin: 20px 0 28px;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .empty-state {
    color: var(--text-muted);
    font-style: italic;
    text-align: center;
    padding: 40px 0;
  }
</style>

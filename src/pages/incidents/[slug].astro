---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import NewsletterCTA from '../../components/NewsletterCTA.astro';
import StructuredData from '../../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { entrySlug, resolveSortDate } from '../../utils/contentEntries';

const essays = await getCollection('essays', ({ data }) => data.status === 'published');

export async function getStaticPaths() {
  const incidents = await getCollection('incidents', ({ data }) => data.status === 'published');
  return incidents.map((incident) => ({
    params: { slug: entrySlug(incident) },
    props: { incident },
  }));
}

const { incident } = Astro.props;
const incidentBodyModules = import.meta.glob('../../content/incidents/*-content.mdx');
const incidentBodyPath = incident.data.contentFile
  ? `../../content/incidents/${incident.data.contentFile}`
  : '';
const incidentBodyModule = incidentBodyPath && incidentBodyModules[incidentBodyPath]
  ? await incidentBodyModules[incidentBodyPath]()
  : null;
const Content = incidentBodyModule?.default;
const incidentUrl = `/incidents/${entrySlug(incident)}/`;
const incidentDateValue = incident.data.incidentDate ?? incident.data.date ?? incident.data.sortDate;
const incidentDateDisplay = incident.data.displayDate
  || incident.data.incidentDateLabel
  || incident.data.dateLabel
  || (incident.data.incidentDate ? incident.data.incidentDate.toISOString().split('T')[0] : '')
  || resolveSortDate(incident.data)?.toISOString().split('T')[0]
  || '';
const incidentDek = incident.data.summary || incident.data.excerpt;
---

<BaseLayout title={incident.data.title} description={incidentDek}>
  <StructuredData
    type="article"
    data={{
      title: incident.data.title,
      summary: incidentDek,
      date: incidentDateValue,
      sortDate: incident.data.sortDate,
      updated: incident.data.updated,
      author: incident.data.author,
      url: incidentUrl,
      image: incident.data.ogImage,
    }}
  />
  <StructuredData
    type="breadcrumb"
    data={{
      items: [
        { name: 'Home', url: '/' },
        { name: 'Incidents', url: '/incidents/' },
        { name: incident.data.title, url: incidentUrl },
      ],
    }}
  />

  <article class="article-body">
    <header class="article-header">
      <span class="eyebrow">Incident Report</span>
      <h1 class="article-title">{incident.data.title}</h1>
      {incidentDek && <p class="article-dek">{incidentDek}</p>}
      <div class="article-meta">
        {incidentDateDisplay && (
          <time datetime={incidentDateValue?.toISOString() || incidentDateDisplay}>
            {incidentDateDisplay}
          </time>
        )}
        {incident.data.systems.length > 0 && (
          <>
            <span class="meta-separator">-</span>
            <span>{incident.data.systems.join(', ')}</span>
          </>
        )}
        {incident.data.severity && (
          <>
            <span class="meta-separator">-</span>
            <span class={`severity severity--${incident.data.severity}`}>
              {incident.data.severity}
            </span>
          </>
        )}
      </div>
    </header>

    <div class="incident-structure">
      {incidentDek && (
        <section class="incident-section">
          <h2>Summary</h2>
          <p>{incidentDek}</p>
        </section>
      )}

      {incident.data.timeline.length > 0 && (
        <section class="incident-section">
          <h2>Timeline</h2>
          <div class="timeline">
            {incident.data.timeline.map((event) => (
              <div class="timeline-item">
                {(event.label || event.date) && (
                  <time datetime={event.date ? event.date.toISOString() : event.label}>
                    {event.label || event.date?.toISOString().split('T')[0]}
                  </time>
                )}
                <p>{event.event}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      {incident.data.rootCause && (
        <section class="incident-section">
          <h2>Root Cause</h2>
          <p>{incident.data.rootCause}</p>
        </section>
      )}

      {incident.data.contributoryFactors.length > 0 && (
        <section class="incident-section">
          <h2>Contributory Factors</h2>
          <ul>
            {incident.data.contributoryFactors.map((factor) => (
              <li>{factor}</li>
            ))}
          </ul>
        </section>
      )}

      {(incident.data.corroboration || incident.data.sources.length > 0) && (
        <section class="incident-section">
          <h2>Evidence / Sources</h2>
          {incident.data.corroboration && <p class="corroboration">{incident.data.corroboration}</p>}
          {incident.data.sources.length > 0 && (
            <ul class="sources-list">
              {incident.data.sources.map((source) => (
                <li>
                  {source.url ? (
                    <a href={source.url} target="_blank" rel="noopener noreferrer">
                      {source.label}
                    </a>
                  ) : (
                    <span>{source.label}</span>
                  )}
                </li>
              ))}
            </ul>
          )}
        </section>
      )}
    </div>

    <div class="article-content content-body">
      {Content && <Content />}
    </div>

    <RelatedContent
      title="Related Content"
      items={[
        ...incident.data.relatedEssays.map((slug) => {
          const essay = essays.find((e) => entrySlug(e) === slug);
          return essay ? {
            title: essay.data.title,
            href: `/essays/${slug}/`,
            type: 'Essay',
          } : null;
        }),
        ...incident.data.relatedPatterns.map((slug) => {
          const essay = essays.find((e) => entrySlug(e) === slug);
          return essay ? {
            title: essay.data.title,
            href: `/essays/${slug}/`,
            type: 'Pattern',
          } : null;
        }),
      ].filter(Boolean)}
    />

    <NewsletterCTA />
  </article>
</BaseLayout>

<style>
  .article-header {
    margin-bottom: 48px;
    max-width: var(--measure);
  }

  .article-title {
    font-size: var(--text-3xl);
    margin: 12px 0 16px;
  }

  .article-dek {
    font-size: var(--text-md);
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    font-size: var(--text-sm);
    color: var(--text-light);
  }

  .meta-separator {
    color: var(--border);
  }

  .severity {
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: var(--text-xs);
  }

  .severity--critical { color: #c0392b; }
  .severity--high { color: #e67e22; }
  .severity--moderate { color: #f39c12; }
  .severity--low { color: var(--text-light); }

  .incident-structure {
    margin-bottom: 48px;
  }

  .incident-section {
    margin-bottom: 32px;
  }

  .incident-section h2 {
    font-size: var(--text-lg);
    margin-bottom: 12px;
  }

  .timeline {
    border-left: 2px solid var(--border-light);
    padding-left: 20px;
  }

  .timeline-item {
    margin-bottom: 16px;
    position: relative;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: -25px;
    top: 6px;
    width: 8px;
    height: 8px;
    background: var(--border);
    border-radius: 50%;
  }

  .timeline-item time {
    display: block;
    font-size: var(--text-xs);
    color: var(--text-light);
    margin-bottom: 4px;
  }

  .corroboration {
    font-style: italic;
    color: var(--text-muted);
    margin-bottom: 16px;
    padding: 12px;
    background: var(--bg-card);
    border-left: 3px solid var(--border);
  }

  .sources-list {
    list-style: none;
  }

  .sources-list li {
    margin-bottom: 8px;
  }

  .article-content {
    max-width: var(--measure);
  }
</style>

---
import '../styles/global.css';
import Analytics from '../components/Analytics.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Post-Incident Analysis of AI Failure', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const defaultOgSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630"><rect width="1200" height="630" fill="#F8F7F4"/><rect x="60" y="60" width="1080" height="510" fill="none" stroke="#1F2933" stroke-width="2"/><text x="90" y="170" fill="#1F2933" font-family="Georgia, serif" font-size="44" letter-spacing="2">THE FORENSIC BRIEF</text><text x="90" y="245" fill="#4B5563" font-family="Arial, sans-serif" font-size="24">${title.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')}</text></svg>`;
const defaultOgImage = `data:image/svg+xml;charset=UTF-8,${encodeURIComponent(defaultOgSvg)}`;
const socialImage = ogImage || defaultOgImage;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={description}>
    <title>{title} | The Forensic Brief</title>
    <link rel="canonical" href={canonicalURL}>

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:url" content={canonicalURL}>
    <meta property="og:site_name" content="The Forensic Brief">
    <meta property="og:image" content={socialImage}>

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={socialImage}>

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="The Forensic Brief" href="/rss.xml">

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=1" sizes="any">
    <link rel="icon" type="image/png" sizes="32x32" href="/forensic-favicon-cream.png?v=3">

    <!-- Performance hints -->
    <meta name="theme-color" content="#F8F7F4">
    <meta name="color-scheme" content="light dark">

    <!-- Pagefind search (only available after build) -->
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" media="print" onload="this.media='all'">
  </head>
  <body class="bg-bible-scripture">
    <a href="#main-content" class="skip-to-content">Skip to content</a>

    <header class="site-header">
      <div class="site-brand">
        <img class="site-brand-logo" src="/forensic-brand-mark.png" alt="" aria-hidden="true" width="48" height="48">
        <div class="site-title" role="heading" aria-level="1">The Forensic Brief</div>
      </div>
      <hr class="header-divider">
      <p class="site-subtitle">Post-Incident Analysis of AI Failure</p>
    </header>

    <nav class="site-nav" aria-label="Primary navigation">
      <ul>
        <li><a href="/incidents/">Incidents</a></li>
        <li><a href="/essays/">Essays</a></li>
        <li><a href="/books/">Books</a></li>
        <li><a href="/observations/">Observations</a></li>
        <li><a href="/artifacts/">Artifacts</a></li>
        <li><a href="/about/">About</a></li>
      </ul>
    </nav>

    <main id="main-content" class="site-main" data-pagefind-body>
      <slot />
    </main>

    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} The Forensic Brief. All rights reserved.</p>
      <ul>
        <li><a href="/disclaimer/">Disclaimer</a></li>
        <li><a href="/methodology/">Methodology</a></li>
      </ul>
    </footer>

    <Analytics />
  </body>
</html>

<style>
  .site-header {
    text-align: center;
    margin-bottom: 1.5rem;
    width: 100%;
    padding: 3rem 1rem 0;
  }

  .site-brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    margin: 0 auto 0.4rem;
    line-height: 1;
  }

  .site-brand-logo {
    width: clamp(2.35rem, 3.4vw, 2.8rem);
    height: clamp(2.35rem, 3.4vw, 2.8rem);
    display: block;
    flex: 0 0 auto;
    object-fit: contain;
  }

  .site-title {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: clamp(2rem, 5vw, 2.5rem);
    font-weight: 400;
    margin: 0 0 0.5rem 0;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--text-primary);
  }

  .header-divider {
    border: none;
    border-top: 1px solid var(--text-primary);
    width: 100%;
    max-width: 400px;
    margin: 0 auto 0.5rem auto;
  }

  .site-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    color: #1F2933;
    margin: 0;
    font-weight: 400;
  }

  .site-nav {
    width: 100%;
    padding: 0 1rem;
    margin-bottom: 2rem;
  }

  .site-nav ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
    list-style: none;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 0;
  }

  .site-nav li a {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .site-nav li a:hover {
    text-decoration: underline;
  }

  .site-main {
    width: 100%;
    max-width: var(--max-width);
    padding: 0 1rem 2rem;
  }

  .site-footer {
    margin-top: 3rem;
    padding: 2rem 0;
    border-top: 1px solid var(--border);
    text-align: center;
    font-size: 0.9rem;
    color: var(--text-muted);
    width: 100%;
  }

  .site-footer p {
    font-size: 1rem;
    color: var(--text-muted);
    margin: 0;
  }

  .site-footer ul {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0 0;
    display: flex;
    justify-content: center;
    gap: 2rem;
  }

  .site-footer a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .site-footer a:hover {
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .site-header {
      padding: 2rem 1rem 0;
    }
    .site-brand {
      gap: 0.5rem;
    }
    .site-brand-logo {
      width: 1.65rem;
      height: 1.65rem;
    }
    .site-title {
      font-size: 1.45rem;
      line-height: 1;
      white-space: nowrap;
    }
    .site-subtitle {
      font-size: 0.95rem;
    }
    .site-nav ul {
      gap: 1rem;
    }
    .site-nav li a {
      font-size: 0.85rem;
    }
  }
</style>

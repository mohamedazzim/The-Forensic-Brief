---
interface Props {
  type: 'article' | 'book' | 'breadcrumb' | 'webpage' | 'collection' | 'organization' | 'creativework';
  data: Record<string, any>;
}

const { type, data } = Astro.props;

let structuredData: Record<string, any> = {};
const toIsoDate = (value?: Date | string) => {
  if (!value) return undefined;
  if (value instanceof Date) return value.toISOString();

  const parsed = new Date(value);
  return Number.isNaN(parsed.valueOf()) ? undefined : parsed.toISOString();
};

if (type === 'article') {
  const publishedDate = toIsoDate(data.date || data.sortDate);
  const modifiedDate = toIsoDate(data.updated) || publishedDate;

  structuredData = {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: data.title,
    description: data.summary,
    datePublished: publishedDate,
    dateModified: modifiedDate,
    author: {
      '@type': 'Person',
      name: data.author || 'Dr. Anandkumar Prakasam',
    },
    publisher: {
      '@type': 'Organization',
      name: 'The Forensic Brief',
      url: 'https://theforensicbrief.com',
    },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': `https://theforensicbrief.com${data.url}`,
    },
  };

  if (!publishedDate) delete structuredData.datePublished;
  if (!modifiedDate) delete structuredData.dateModified;
  
  if (data.image) {
    structuredData.image = data.image;
  }
} else if (type === 'book') {
  structuredData = {
    '@context': 'https://schema.org',
    '@type': 'Book',
    name: data.title,
    description: data.summary,
    author: {
      '@type': 'Person',
      name: data.author || 'Dr. Anandkumar Prakasam',
    },
    publisher: {
      '@type': 'Organization',
      name: 'The Forensic Brief',
    },
    url: `https://theforensicbrief.com${data.url}`,
    ...(data.cover ? { image: data.cover } : {}),
    ...(data.isbn ? { isbn: data.isbn } : {}),
    ...(data.pages ? { numberOfPages: data.pages } : {}),
  };
} else if (type === 'breadcrumb') {
  structuredData = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: data.items.map((item: any, index: number) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.name,
      item: `https://theforensicbrief.com${item.url}`,
    })),
  };
} else if (type === 'webpage') {
  structuredData = {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: data.name || 'The Forensic Brief',
    url: data.url || 'https://theforensicbrief.com',
    potentialAction: data.searchUrl ? {
      '@type': 'SearchAction',
      target: data.searchUrl,
      'query-input': 'required name=q',
    } : undefined,
  };
  if (!data.searchUrl) delete structuredData.potentialAction;
} else if (type === 'collection') {
  structuredData = {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: data.name,
    description: data.description,
    url: data.url,
  };
  if (data.breadcrumbs) {
    structuredData.breadcrumb = data.breadcrumbs;
  }
} else if (type === 'organization') {
  structuredData = {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: data.name || 'The Forensic Brief',
    url: data.url || 'https://theforensicbrief.com',
  };
} else if (type === 'creativework') {
  structuredData = {
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    name: data.title,
    description: data.summary,
    url: `https://theforensicbrief.com${data.url}`,
    author: {
      '@type': 'Person',
      name: data.author || 'Dr. Anandkumar Prakasam',
    },
    publisher: {
      '@type': 'Organization',
      name: 'The Forensic Brief',
    },
  };
  if (data.license) {
    structuredData.license = data.license;
  }
}
---

<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

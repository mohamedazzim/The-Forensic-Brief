---
interface Props {
  prev?: string;
  next?: string;
  book?: string;
  artifact?: string;
  series?: string;
}

const { prev, next, book, artifact, series } = Astro.props;

const seriesNames: Record<string, string> = {
  'human-in-control': 'Human in Control',
  'out-of-bounds': 'Out of Bounds',
  'accountable-autonomy': 'Accountable Autonomy',
  'six-dimensions': 'The Six Dimensions',
  'the-burden': 'The Burden',
};
---

<nav class="series-nav" aria-label="Series navigation">
  <div class="series-nav-main">
    {prev && (
      <a href={`/essays/${prev}/`} class="nav-link nav-prev">
        <span class="nav-label">← Previous</span>
      </a>
    )}
    
    <div class="series-nav-center">
      {series && (
        <a href={`/essays/${series}/`} class="nav-link nav-series">
          {seriesNames[series] || series}
        </a>
      )}
      {book && (
        <a href={`/books/${book}/`} class="nav-link nav-book">
          Read the Book
        </a>
      )}
      {artifact && (
        <a href={`/artifacts/${artifact}/`} class="nav-link nav-artifact">
          View Artifact
        </a>
      )}
    </div>

    {next && (
      <a href={`/essays/${next}/`} class="nav-link nav-next">
        <span class="nav-label">Next →</span>
      </a>
    )}
  </div>
</nav>

<style>
  .series-nav {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--border-light);
  }

  .series-nav-main {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }

  .series-nav-center {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .nav-link {
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-decoration: none;
    border: none;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-label {
    font-size: var(--text-sm);
  }

  .nav-series {
    font-weight: 500;
    color: var(--text-primary);
  }

  @media (max-width: 600px) {
    .series-nav-main {
      flex-direction: column;
      gap: 12px;
    }

    .series-nav-center {
      flex-direction: column;
      align-items: center;
    }
  }
</style>

---
interface Props {
  prev?: {
    slug: string;
    title: string;
  };
  next?: {
    slug: string;
    title: string;
  };
  book?: {
    slug: string;
    title: string;
  };
  artifact?: {
    slug: string;
    title: string;
  };
  series?: string;
}

const { prev, next, book, artifact, series } = Astro.props;

const seriesNames: Record<string, string> = {
  'human-in-control': 'Human in Control',
  'out-of-bounds': 'Out of Bounds',
  'accountable-autonomy': 'Accountable Autonomy',
  'six-dimensions': 'The Six Dimensions',
  'the-burden': 'The Burden',
};
---

{(prev || next || series || book || artifact) && (
  <nav class="series-nav" aria-label="Series navigation">
    <div class="series-nav-main">
      <div class="series-nav-side">
        {prev ? (
          <a href={`/essays/${prev.slug}/`} class="nav-link nav-prev">
            <span class="nav-label">← Previous</span>
            <span class="nav-title">{prev.title}</span>
          </a>
        ) : (
          <span class="nav-placeholder" aria-hidden="true"></span>
        )}
      </div>

      <div class="series-nav-center">
        {series && (
          <a href={`/essays/${series}/`} class="nav-link nav-series">
            <span class="nav-label">Series</span>
            <span class="nav-title">{seriesNames[series] || series}</span>
          </a>
        )}
        {book && (
          <a href={`/books/${book.slug}/`} class="nav-link nav-book">
            <span class="nav-label">Book</span>
            <span class="nav-title">{book.title}</span>
          </a>
        )}
        {artifact && (
          <a href={`/artifacts/${artifact.slug}/`} class="nav-link nav-artifact">
            <span class="nav-label">Artifact</span>
            <span class="nav-title">{artifact.title}</span>
          </a>
        )}
      </div>

      <div class="series-nav-side series-nav-side--end">
        {next ? (
          <a href={`/essays/${next.slug}/`} class="nav-link nav-next">
            <span class="nav-label">Next →</span>
            <span class="nav-title">{next.title}</span>
          </a>
        ) : (
          <span class="nav-placeholder" aria-hidden="true"></span>
        )}
      </div>
    </div>
  </nav>
)}

<style>
  .series-nav {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--border-light);
  }

  .series-nav-main {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 16px;
  }

  .series-nav-side {
    display: flex;
    min-height: 48px;
  }

  .series-nav-side--end {
    justify-content: flex-end;
  }

  .nav-placeholder {
    display: block;
    min-width: 1px;
  }

  .nav-link {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-decoration: none;
    border: none;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-light);
  }

  .nav-title {
    font-size: var(--text-sm);
    line-height: 1.4;
  }

  .nav-series .nav-title,
  .nav-book .nav-title,
  .nav-artifact .nav-title {
    font-weight: 500;
    color: var(--text-primary);
  }

  .series-nav-center {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }

  @media (max-width: 600px) {
    .series-nav-main {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .series-nav-center {
      flex-direction: column;
      align-items: center;
    }

    .series-nav-side,
    .series-nav-side--end {
      justify-content: center;
    }
  }
</style>

---
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'Stay Informed', 
  description = 'Get notified when new incidents, essays, and artifacts are published.' 
} = Astro.props;
const newsletterUrl = import.meta.env.PUBLIC_NEWSLETTER_URL || '';
---

<section class="newsletter-cta">
  <h2 class="newsletter-title">{title}</h2>
  <p class="newsletter-description">{description}</p>
  
  {newsletterUrl ? (
  <form class="newsletter-form" id="newsletter-form" action={newsletterUrl} method="post" target="_blank" rel="noopener noreferrer">
    <input 
      type="email" 
      id="newsletter-email"
      name="email"
      placeholder="your@email.com" 
      required 
      aria-label="Email address"
    />
    <button type="submit">Subscribe</button>
  </form>
  ) : (
  <div class="newsletter-disabled" role="status" aria-live="polite">
    <p>Newsletter signup is not configured yet.</p>
    <button type="button" disabled>Subscribe</button>
  </div>
  )}
  
  <p class="newsletter-privacy">
    No spam. Unsubscribe anytime. View our <a href="/disclaimer/">privacy policy</a>.
  </p>
</section>

<style>
  .newsletter-cta {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    padding: 48px 32px;
    text-align: center;
    margin-top: 64px;
  }

  .newsletter-title {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.5rem;
    margin-bottom: 12px;
  }

  .newsletter-description {
    color: var(--text-muted);
    margin-bottom: 24px;
    font-size: var(--text-sm);
  }

  .newsletter-form {
    display: flex;
    gap: 12px;
    justify-content: center;
    max-width: 400px;
    margin: 0 auto;
  }

  .newsletter-form input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text-primary);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 0.9rem;
  }

  .newsletter-form input:focus {
    outline: none;
    border-color: var(--text-primary);
  }

  .newsletter-form button {
    padding: 12px 24px;
    background: var(--text-primary);
    color: var(--bg);
    border: none;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 0.9rem;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .newsletter-form button:hover {
    opacity: 0.9;
  }

  .newsletter-disabled {
    display: grid;
    gap: 12px;
    justify-items: center;
  }

  .newsletter-disabled p {
    margin: 0;
    color: var(--text-muted);
  }

  .newsletter-disabled button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .newsletter-privacy {
    margin-top: 16px;
    font-size: var(--text-xs);
    color: var(--text-light);
  }

  .newsletter-privacy a {
    color: var(--text-light);
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .newsletter-form {
      flex-direction: column;
    }
  }
</style>

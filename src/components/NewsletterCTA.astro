---
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'Stay Informed', 
  description = 'Get notified when new incidents, essays, and artifacts are published.' 
} = Astro.props;
const configuredNewsletterUrl = import.meta.env.PUBLIC_NEWSLETTER_URL?.trim() || '';
const defaultNewsletterUrl = import.meta.env.DEV ? '' : 'https://theforensicbriefazzim.substack.com/';
const newsletterUrl = configuredNewsletterUrl || defaultNewsletterUrl;
---

<section class="newsletter-cta">
  <h2 class="newsletter-title">{title}</h2>
  <p class="newsletter-description">{description}</p>
  
  {newsletterUrl ? (
  <div class="newsletter-action">
    <a class="newsletter-button" href={newsletterUrl} target="_blank" rel="noopener noreferrer">Subscribe on Substack</a>
    <p class="newsletter-action-note">You will subscribe on Substack in a new tab.</p>
  </div>
  ) : (
  <div class="newsletter-disabled" role="status" aria-live="polite">
    <p>Newsletter signup is not configured yet.</p>
    <button type="button" disabled>Subscribe</button>
  </div>
  )}
  
  <p class="newsletter-privacy">
    No spam. Unsubscribe anytime. View our <a href="/disclaimer/">privacy policy</a>.
  </p>
</section>

<style>
  .newsletter-cta {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    padding: 48px 32px;
    text-align: center;
    margin-top: 64px;
  }

  .newsletter-title {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.5rem;
    margin-bottom: 12px;
  }

  .newsletter-description {
    color: var(--text-muted);
    margin-bottom: 24px;
    font-size: var(--text-sm);
  }

  .newsletter-action {
    display: grid;
    gap: 10px;
    justify-items: center;
  }

  .newsletter-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    background: var(--text-primary);
    color: var(--bg);
    border: none;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 0.9rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .newsletter-button:hover {
    opacity: 0.9;
  }

  .newsletter-action-note {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-xs);
  }

  .newsletter-disabled {
    display: grid;
    gap: 12px;
    justify-items: center;
  }

  .newsletter-disabled p {
    margin: 0;
    color: var(--text-muted);
  }

  .newsletter-disabled button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .newsletter-privacy {
    margin-top: 16px;
    font-size: var(--text-xs);
    color: var(--text-light);
  }

  .newsletter-privacy a {
    color: var(--text-light);
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .newsletter-action {
      justify-items: stretch;
    }
  }
</style>

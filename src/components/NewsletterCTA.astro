---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Stay Informed',
  description = 'Get notified when new incidents, essays, and artifacts are published.',
} = Astro.props;
const newsletterUrl = import.meta.env.PUBLIC_NEWSLETTER_URL?.trim() || '';
---

{newsletterUrl ? (
  <section class="newsletter-cta">
    <h2 class="newsletter-title">{title}</h2>
    <p class="newsletter-description">{description}</p>
    <div class="newsletter-action">
      <a class="newsletter-button" href={newsletterUrl} target="_blank" rel="noopener noreferrer">Subscribe</a>
    </div>
    <p class="newsletter-privacy">
      No spam. Unsubscribe anytime. View our <a href="/disclaimer/">privacy policy</a>.
    </p>
  </section>
) : null}

<style>
  .newsletter-cta {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    padding: 48px 32px;
    text-align: center;
    margin-top: 64px;
  }

  .newsletter-title {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.5rem;
    margin-bottom: 12px;
  }

  .newsletter-description {
    color: var(--text-muted);
    margin-bottom: 24px;
    font-size: var(--text-sm);
  }

  .newsletter-action {
    display: grid;
    gap: 10px;
    justify-items: center;
  }

  .newsletter-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    background: var(--text-primary);
    color: var(--bg);
    border: none;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 0.9rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .newsletter-button:hover {
    opacity: 0.9;
  }

  .newsletter-privacy {
    margin-top: 16px;
    font-size: var(--text-xs);
    color: var(--text-light);
  }

  .newsletter-privacy a {
    color: var(--text-light);
    text-decoration: underline;
  }
</style>

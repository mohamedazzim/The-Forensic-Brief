---
interface Props {
  title: string;
  excerpt?: string;
  date?: string;
  category: string;
  href: string;
  linkText?: string;
  dataSeries?: string;
  dataCategory?: string;
  dataSeverity?: string;
  dataDomain?: string;
  dataVendor?: string;
  dataType?: string;
  dataTopics?: string;
}

const { title, excerpt, date, category, href, linkText = 'Read report', dataSeries, dataCategory, dataSeverity, dataDomain, dataVendor, dataType, dataTopics } = Astro.props;
---

<article class="article-card" data-series={dataSeries} data-category={dataCategory} data-severity={dataSeverity} data-domain={dataDomain} data-vendor={dataVendor} data-type={dataType} data-topics={dataTopics}>
  <span class="card-category">{category}</span>
  <h3 class="card-title">
    <a href={href}>{title}</a>
  </h3>
  {excerpt && <p class="card-excerpt">{excerpt}</p>}
  <div class="card-meta">
    {date ? <time datetime={date}>{date}</time> : <span></span>}
    <a href={href} class="card-read-more">{linkText} -></a>
  </div>
</article>

<style>
  .article-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    padding: 24px;
    position: relative;
  }

  .card-category {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-light);
    margin-bottom: 10px;
    display: block;
  }

  .card-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.4;
    margin-bottom: 10px;
  }

  .card-title a {
    color: inherit;
    text-decoration: none;
    border: none;
  }

  .card-title a:hover {
    color: var(--text-muted);
  }

  .card-excerpt {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.78rem;
    color: var(--text-light);
  }

  .card-read-more {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 0.8rem;
    color: var(--text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
  }

  .card-read-more:hover {
    color: var(--text-muted);
    border-color: var(--text-muted);
  }
</style>

---

<div class="search-root" id="search-root">
  <div class="search-bar">
    <svg class="search-bar-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    <input 
      type="text" 
      id="search-input" 
      class="search-bar-input" 
      placeholder="Search the publication..."
      aria-label="Search articles, essays, incidents"
      aria-autocomplete="list"
      aria-controls="search-panel"
      aria-expanded="false"
      role="combobox"
    />
    <span class="search-bar-hint">ESC</span>
  </div>
  <div id="search-panel" class="search-panel" role="listbox"></div>
</div>

<script type="module">
  (function() {
    var pagefind = null;
    var activeIdx = -1;
    var cards = [];
    var latestQuery = '';

    var root = document.getElementById('search-root');
    var input = document.getElementById('search-input');
    var panel = document.getElementById('search-panel');
    if (!root || !input || !panel) return;

    function init() {
      import('/pagefind/pagefind.js').then(function(mod) {
        pagefind = mod;
        return pagefind.init();
      }).catch(function() {});
    }

    function cat(url) {
      if (/\/incidents\//.test(url)) return 'Incident';
      if (/\/essays\//.test(url)) return 'Essay';
      if (/\/observations\//.test(url)) return 'Observation';
      if (/\/books\//.test(url)) return 'Book';
      if (/\/artifacts\//.test(url)) return 'Artifact';
      if (/\/topics\//.test(url)) return 'Topic';
      return 'Page';
    }

    function groupByCategory(results) {
      var order = ['Incident', 'Essay', 'Observation', 'Book', 'Artifact', 'Topic'];
      var map = {};
      results.forEach(function(r) { var c = cat(r.url); if (!map[c]) map[c] = []; map[c].push(r); });
      var sorted = {};
      order.forEach(function(k) { if (map[k]) sorted[k] = map[k]; });
      Object.keys(map).forEach(function(k) { if (!sorted[k]) sorted[k] = map[k]; });
      return sorted;
    }

    function fmtDate(d) {
      if (!d) return '';
      try { return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }); } catch(e) { return ''; }
    }

    function cleanExcerpt(raw) {
      if (!raw) return '';
      var text = raw.replace(/<[^>]+>/g, '').replace(/\u200B/g, '').trim();
      var sentences = text.split(/(?<=[.!?])\s+/);
      var best = '';
      for (var i = 0; i < sentences.length; i++) {
        if (sentences[i].length > 20) { best = sentences[i]; break; }
      }
      if (!best && sentences.length) best = sentences[0];
      if (best.length > 160) best = best.substring(0, 157) + '...';
      return best;
    }

    function hl(text, query) {
      if (!query || !text) return text || '';
      var terms = query.toLowerCase().split(/\s+/).filter(function(t) { return t.length > 1; });
      var out = text;
      terms.forEach(function(t) {
        var re = new RegExp('(' + t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
        out = out.replace(re, '<mark>$1</mark>');
      });
      return out;
    }

    function skeletonHTML() {
      return '<div class="sp-skel">' +
        '<div class="sp-skel-item"><div class="sp-skel-badge"></div><div class="sp-skel-line" style="width:65%"></div><div class="sp-skel-line sm" style="width:80%"></div></div>' +
        '<div class="sp-skel-item"><div class="sp-skel-badge"></div><div class="sp-skel-line" style="width:55%"></div><div class="sp-skel-line sm" style="width:70%"></div></div>' +
        '<div class="sp-skel-item"><div class="sp-skel-badge"></div><div class="sp-skel-line" style="width:45%"></div><div class="sp-skel-line sm" style="width:60%"></div></div>' +
      '</div>';
    }

    function emptyHTML() {
      return '<div class="sp-empty">' +
        '<div class="sp-empty-title">No results found</div>' +
        '<div class="sp-empty-sub">Try one of these searches</div>' +
        '<div class="sp-empty-tags">' +
          '<button class="sp-tag" data-q="AI governance">AI governance</button>' +
          '<button class="sp-tag" data-q="human oversight">Human oversight</button>' +
          '<button class="sp-tag" data-q="automation bias">Automation bias</button>' +
          '<button class="sp-tag" data-q="EU AI Act">EU AI Act</button>' +
          '<button class="sp-tag" data-q="red teaming">Red teaming</button>' +
          '<button class="sp-tag" data-q="Air Canada">Air Canada</button>' +
        '</div>' +
      '</div>';
    }

    function resultsHTML(groups, query) {
      var html = '';
      Object.keys(groups).forEach(function(catName) {
        var items = groups[catName];
        html += '<div class="sp-group"><div class="sp-group-label">' + catName + '</div>';
        items.forEach(function(r) {
          var title = r.meta && r.meta.title ? r.meta.title : '';
          var snippet = cleanExcerpt(r.plain_excerpt || r.raw_content || '');
          var date = r.meta && r.meta.date ? fmtDate(r.meta.date) : '';
          html += '<a href="' + r.url + '" class="sp-card" role="option">' +
            '<div class="sp-card-body">' +
              '<div class="sp-card-title">' + hl(title, query) + '</div>' +
              (snippet ? '<div class="sp-card-snippet">' + hl(snippet, query) + '</div>' : '') +
            '</div>' +
            (date ? '<div class="sp-card-date">' + date + '</div>' : '') +
          '</a>';
        });
        html += '</div>';
      });
      return html;
    }

    function open() { panel.classList.add('open'); input.setAttribute('aria-expanded', 'true'); }
    function close() { panel.classList.remove('open'); input.setAttribute('aria-expanded', 'false'); activeIdx = -1; }
    function markActive() {
      cards = panel.querySelectorAll('.sp-card');
      cards.forEach(function(c, i) {
        c.classList.toggle('active', i === activeIdx);
        if (i === activeIdx) c.scrollIntoView({ block: 'nearest' });
      });
    }

    var timer;
    input.addEventListener('input', function(e) {
      clearTimeout(timer);
      var q = e.target.value.trim();
      latestQuery = q;
      if (q.length < 2) { close(); return; }
      timer = setTimeout(async function() {
        if (!pagefind) { panel.innerHTML = '<div class="sp-msg">Search available after build</div>'; open(); return; }
        panel.innerHTML = skeletonHTML(); open();
        try {
          var res = await pagefind.search(q);
          var data = await Promise.all(res.results.slice(0, 10).map(function(r) { return r.data(); }));
          if (latestQuery !== q) return;
          if (data.length === 0) { panel.innerHTML = emptyHTML(); }
          else { panel.innerHTML = resultsHTML(groupByCategory(data), q); }
          activeIdx = -1;
        } catch(err) { panel.innerHTML = '<div class="sp-msg">Something went wrong</div>'; }
      }, 250);
    });

    input.addEventListener('keydown', function(e) {
      cards = panel.querySelectorAll('.sp-card');
      if (e.key === 'ArrowDown') { e.preventDefault(); activeIdx = Math.min(activeIdx + 1, cards.length - 1); markActive(); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); activeIdx = Math.max(activeIdx - 1, 0); markActive(); }
      else if (e.key === 'Enter' && activeIdx >= 0 && cards[activeIdx]) { e.preventDefault(); cards[activeIdx].click(); }
      else if (e.key === 'Escape') { close(); input.blur(); }
    });

    document.addEventListener('click', function(e) { if (!root.contains(e.target)) close(); });
    input.addEventListener('focus', function() { if (panel.innerHTML.trim()) open(); });

    panel.addEventListener('click', function(e) {
      var tag = e.target.closest('.sp-tag');
      if (tag) { input.value = tag.getAttribute('data-q'); input.dispatchEvent(new Event('input')); }
    });

    init();
  })();
</script>

<style>
  .search-root {
    position: relative;
    width: 100%;
    max-width: 500px;
  }

  /* ── Input ── */
  .search-bar {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-bar-input {
    width: 100%;
    padding: 12px 60px 12px 40px;
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 8px;
    background: #F8F7F4;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 14px;
    color: var(--text-primary);
    outline: none;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .search-bar-input::placeholder {
    color: var(--text-light);
    font-style: italic;
  }

  .search-bar-input:focus {
    border-color: rgba(0, 0, 0, 0.2);
    box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.04);
  }

  .search-bar-icon {
    position: absolute;
    left: 13px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-light);
    pointer-events: none;
  }

  .search-bar-hint {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 10px;
    font-family: 'Inter', monospace;
    color: var(--border);
    background: rgba(0, 0, 0, 0.03);
    border: 1px solid var(--border-light);
    border-radius: 4px;
    padding: 2px 5px;
    pointer-events: none;
    letter-spacing: 0.04em;
  }

  /* ── Panel ── */
  .search-panel {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background: rgba(248, 247, 244, 0.97);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 10px;
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.06);
    max-height: 440px;
    overflow-y: auto;
    overflow-x: hidden;
    z-index: 200;
    padding: 6px;
  }

  .search-panel.open {
    display: block;
  }

  .search-panel::-webkit-scrollbar {
    width: 4px;
  }

  .search-panel::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.1);
    border-radius: 4px;
  }

  /* ── Group ── */
  .sp-group {
    margin-bottom: 2px;
  }

  .sp-group:not(:last-child) {
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    margin-bottom: 4px;
    padding-bottom: 4px;
  }

  .sp-group-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-light);
    opacity: 0.65;
    padding: 10px 14px 4px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .sp-group-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(0, 0, 0, 0.06);
  }

  /* ── Card ── */
  .sp-card {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 14px;
    border-radius: 8px;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .sp-card:hover,
  .sp-card.active {
    background: rgba(0, 0, 0, 0.025);
  }

  .sp-card.active {
    transform: translateY(-1px);
  }

  .sp-card-body {
    flex: 1;
    min-width: 0;
  }

  .sp-card-title {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 15px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--text-primary);
    margin-bottom: 3px;
    transition: color 0.15s ease;
  }

  .sp-card:hover .sp-card-title,
  .sp-card.active .sp-card-title {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  .sp-card-snippet {
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-muted);
    opacity: 0.75;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .sp-card-date {
    font-size: 11px;
    color: var(--text-light);
    opacity: 0.5;
    white-space: nowrap;
    padding-top: 3px;
  }

  .sp-card mark {
    background: rgba(200, 170, 100, 0.3);
    padding: 0 1px;
    border-radius: 2px;
    color: inherit;
  }

  /* ── Skeleton ── */
  .sp-skel {
    padding: 8px;
  }

  .sp-skel-item {
    padding: 12px 14px;
    border-radius: 8px;
    margin-bottom: 2px;
  }

  .sp-skel-badge {
    width: 48px;
    height: 9px;
    border-radius: 4px;
    background: rgba(0, 0, 0, 0.05);
    margin-bottom: 10px;
  }

  .sp-skel-line {
    height: 11px;
    border-radius: 6px;
    background: linear-gradient(90deg, rgba(0,0,0,0.04) 25%, rgba(0,0,0,0.07) 50%, rgba(0,0,0,0.04) 75%);
    background-size: 200% 100%;
    animation: sp-shimmer 1.6s infinite;
    margin-bottom: 8px;
  }

  .sp-skel-line.sm {
    height: 10px;
    margin-bottom: 0;
  }

  @keyframes sp-shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ── Empty ── */
  .sp-empty {
    padding: 28px 16px;
    text-align: center;
  }

  .sp-empty-title {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 15px;
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 6px;
  }

  .sp-empty-sub {
    font-size: 13px;
    color: var(--text-light);
    margin-bottom: 14px;
  }

  .sp-empty-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
  }

  .sp-tag {
    font-size: 12px;
    font-family: 'Inter', sans-serif;
    padding: 5px 12px;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 20px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .sp-tag:hover {
    background: var(--text-primary);
    color: var(--bg);
    border-color: var(--text-primary);
  }

  .sp-msg {
    padding: 24px;
    text-align: center;
    font-size: 13px;
    color: var(--text-light);
    font-style: italic;
  }

  /* ── Mobile ── */
  @media (max-width: 600px) {
    .search-root {
      max-width: 100%;
    }

    .search-bar-input {
      font-size: 16px;
      padding: 11px 50px 11px 38px;
    }

    .search-bar-hint {
      display: none;
    }

    .search-panel {
      border-radius: 8px;
      max-height: 50vh;
    }

    .sp-card {
      padding: 10px 12px;
    }

    .sp-card-title {
      font-size: 14px;
    }

    .sp-card-snippet {
      font-size: 12px;
    }
  }
</style>

<div class="search-container">
  <div class="search-input-wrapper">
    <input 
      type="text" 
      id="search-input" 
      class="search-input" 
      placeholder="Search articles..."
      aria-label="Search"
    />
    <span class="search-icon">⌕</span>
  </div>
  <div id="search-results" class="search-results hidden"></div>
</div>

<script type="module">
  var pagefind = null;

  async function loadPagefind() {
    try {
      var mod = await import('/pagefind/pagefind.js');
      pagefind = mod;
      await pagefind.init();
      return true;
    } catch(e) {
      console.warn('Pagefind not available:', e.message);
      return false;
    }
  }

  document.addEventListener('DOMContentLoaded', async function() {
    var input = document.getElementById('search-input');
    var resultsContainer = document.getElementById('search-results');
    if (!input || !resultsContainer) return;

    await loadPagefind();
    var debounceTimer;

    input.addEventListener('input', function(e) {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(async function() {
        var query = e.target.value.trim();
        if (query.length < 2) {
          resultsContainer.classList.add('hidden');
          return;
        }
        if (!pagefind) {
          resultsContainer.innerHTML = '<p class="no-results">Search requires a build. Run npm run build first.</p>';
          resultsContainer.classList.remove('hidden');
          return;
        }
        try {
          var search = await pagefind.search(query);
          var results = await Promise.all(
            search.results.slice(0, 8).map(function(r) { return r.data(); })
          );
          if (results.length === 0) {
            resultsContainer.innerHTML = '<p class="no-results">No results found.</p>';
          } else {
            resultsContainer.innerHTML = '<div class="results-header">Results for "' + query + '"</div>' +
              results.map(function(r) {
                var category = getCategory(r);
                var date = r.meta && r.meta.date ? formatDate(r.meta.date) : '';
                var excerpt = r.plain_excerpt || r.excerpt || '';
                excerpt = excerpt.replace(/<[^>]+>/g, '').substring(0, 150);
                if (excerpt.length === 150) excerpt += '...';
                return '<a href="' + r.url + '" class="result-item">' +
                  '<div class="result-top">' +
                    (category ? '<span class="result-category">' + category + '</span>' : '') +
                    (date ? '<span class="result-date">' + date + '</span>' : '') +
                  '</div>' +
                  '<span class="result-title">' + (r.meta && r.meta.title ? r.meta.title : 'Untitled') + '</span>' +
                  '<span class="result-excerpt">' + excerpt + '</span>' +
                '</a>';
              }).join('');
          }
          resultsContainer.classList.remove('hidden');
        } catch (err) {
          console.error('Search error:', err);
        }
      }, 300);
    });

    document.addEventListener('click', function(e) {
      if (!input.contains(e.target) && !resultsContainer.contains(e.target)) {
        resultsContainer.classList.add('hidden');
      }
    });

    function getCategory(r) {
      var url = r.url || '';
      if (url.includes('/incidents/')) return 'Incident Report';
      if (url.includes('/essays/')) return 'Essay';
      if (url.includes('/books/')) return 'Book';
      if (url.includes('/observations/')) return 'Observation';
      if (url.includes('/artifacts/')) return 'Artifact';
      if (url.includes('/topics/')) return 'Topic';
      if (url.includes('/about/')) return 'About';
      if (url.includes('/methodology/')) return 'Methodology';
      return '';
    }

    function formatDate(d) {
      if (!d) return '';
      try {
        var date = new Date(d);
        return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
      } catch(e) {
        return d;
      }
    }
  });
</script>

<style>
  .search-container {
    position: relative;
    width: 100%;
    max-width: 400px;
  }

  .search-input-wrapper {
    position: relative;
  }

  .search-input {
    width: 100%;
    padding: 12px 16px 12px 40px;
    border: 1px solid var(--border);
    background: var(--bg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: var(--text-sm);
    color: var(--text-primary);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--text-primary);
  }

  .search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-light);
    font-size: var(--text-base);
  }

  .search-results {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--bg);
    border: 1px solid var(--border);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    z-index: 100;
    max-height: 480px;
    overflow-y: auto;
  }

  .search-results.hidden {
    display: none;
  }

  .results-header {
    padding: 10px 16px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--border-light);
  }

  .result-item {
    display: block;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border-light);
    text-decoration: none;
    transition: background 0.15s;
  }

  .result-item:last-child {
    border-bottom: none;
  }

  .result-item:hover {
    background: var(--bg-card);
  }

  .result-top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
  }

  .result-category {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
  }

  .result-date {
    font-size: 0.7rem;
    color: var(--text-light);
  }

  .result-title {
    display: block;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.4;
    margin-bottom: 4px;
  }

  .result-excerpt {
    display: block;
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .no-results {
    padding: 16px;
    text-align: center;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }
</style>

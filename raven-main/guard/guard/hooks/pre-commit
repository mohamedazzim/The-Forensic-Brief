#!/bin/bash

# =============================================================================
# Raven вЂ” Pre-commit Hook v3.0
# Three-tier library approval + CVE check (PyPI Safety + GPT-5.4-Cyber)
# =============================================================================

export RAVEN_COMMIT=1

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

VIOLATIONS=0
WARNINGS=0
PROJECT_ROOT=$(git rev-parse --show-toplevel)
MANIFEST="$PROJECT_ROOT/.raven/manifest.json"
SCRIPT_DIR="$PROJECT_ROOT/.claude/scripts"

echo ""
echo -e "${BOLD}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${NC}"
echo -e "${BOLD}  Raven Pre-commit v3.0${NC}"
echo -e "${BOLD}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${NC}"
echo ""

# =============================================================================
# FRAMEWORK REPO DETECTION вЂ” skip all checks if this is a Raven framework repo
# =============================================================================
if [ -f ".raven-framework" ]; then
    echo -e "${GREEN}вњ… Framework repo detected вЂ” skipping manifest check${NC}"
    exit 0
fi

# =============================================================================
# CHECK 0 вЂ” Publisher prohibition: framework dirs must never be committed
# =============================================================================

echo -e "${BLUE}[0/5] Publisher check...${NC}"

FRAMEWORK_BLOCKED=0
for DIR in raven raven-guard .raven-framework .raven-guard; do
    # Check if staged
    if git diff --cached --name-only | grep -q "^$DIR/"; then
        echo ""
        echo -e "${RED}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${NC}"
        echo -e "${RED}в•‘  PUBLISHER PROHIBITION вЂ” COMMIT BLOCKED                      в•‘${NC}"
        echo -e "${RED}в• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј${NC}"
        echo -e "${RED}в•‘                                                               в•‘${NC}"
        echo -e "${RED}в•‘  The Raven framework directory has been detected in           в•‘${NC}"
        echo -e "${RED}в•‘  your staged files:  $DIR/$(printf '%*s' $((33-${#DIR})) '')в•‘${NC}"
        echo -e "${RED}в•‘                                                               в•‘${NC}"
        echo -e "${RED}в•‘  The publisher (Giggso) prohibits committing the Raven        в•‘${NC}"
        echo -e "${RED}в•‘  framework into project repositories. It must live outside   в•‘${NC}"
        echo -e "${RED}в•‘  your project and never be tracked by your project's git.    в•‘${NC}"
        echo -e "${RED}в•‘                                                               в•‘${NC}"
        echo -e "${RED}в•‘  Fix:                                                        в•‘${NC}"
        echo -e "${RED}в•‘  git rm -r --cached $DIR/$(printf '%*s' $((38-${#DIR})) '')в•‘${NC}"
        echo -e "${RED}в•‘  echo \"$DIR/\" >> .gitignore$(printf '%*s' $((36-${#DIR})) '')в•‘${NC}"
        echo -e "${RED}в•‘                                                               в•‘${NC}"
        echo -e "${RED}в•‘  github.com/giggsoinc/raven                                  в•‘${NC}"
        echo -e "${RED}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${NC}"
        echo ""
        FRAMEWORK_BLOCKED=1
    fi

    # Check if already tracked in repo (not just staged)
    if git ls-files --error-unmatch "$DIR/" &>/dev/null 2>&1; then
        echo -e "  ${RED}вќЊ PUBLISHER PROHIBITION: $DIR/ is tracked in git.${NC}"
        echo -e "     Run: git rm -r --cached $DIR/ && echo \"$DIR/\" >> .gitignore"
        FRAMEWORK_BLOCKED=1
    fi
done

[ "$FRAMEWORK_BLOCKED" -eq 1 ] && exit 1
echo -e "  ${GREEN}вњ… Framework dirs not tracked${NC}"
echo ""

# =============================================================================
# CHECK 1 вЂ” Manifest (always hard block if missing)
# =============================================================================

echo -e "${BLUE}[1/5] Manifest check...${NC}"
if [ ! -f "$MANIFEST" ]; then
    echo -e "  ${RED}вќЊ HARD BLOCK: manifest.json missing.${NC}"
    exit 1
fi
if ! python3 -c "import json; json.load(open('$MANIFEST'))" 2>/dev/null; then
    echo -e "  ${RED}вќЊ HARD BLOCK: manifest.json invalid JSON.${NC}"
    exit 1
fi
echo -e "  ${GREEN}вњ… Manifest valid${NC}"
echo ""

# =============================================================================
# CHECK 2 вЂ” Secrets never committed
# =============================================================================

echo -e "${BLUE}[2/5] Secrets check...${NC}"

STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM)

if echo "$STAGED_ALL" | grep -q "manifest.secrets.json"; then
    echo -e "  ${RED}вќЊ HARD BLOCK: manifest.secrets.json staged.${NC}"
    echo -e "     Run: git reset HEAD .raven/manifest.secrets.json"
    ((VIOLATIONS++))
fi

for FILE in $STAGED_ALL; do
    if git show ":$FILE" 2>/dev/null | grep -qE "(api_key|secret_key|password|AWS_SECRET|OPENAI_API_KEY|private_key)\s*=\s*['\"][^'\"]{8,}['\"]"; then
        echo -e "  ${RED}вќЊ HARD BLOCK: Possible secret in $FILE${NC}"
        ((VIOLATIONS++))
    fi
done

[ "$VIOLATIONS" -eq 0 ] && echo -e "  ${GREEN}вњ… No secrets detected${NC}"
echo ""

# =============================================================================
# CHECK 3 вЂ” Library CVE check (three-tier system)
# =============================================================================

echo -e "${BLUE}[3/5] Library CVE check (three-tier)...${NC}"
echo ""

STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$|requirements.*\.txt$|pyproject\.toml$|setup\.py$')

# Stdlib вЂ” never flag
STDLIB="os sys json logging typing datetime pathlib re collections itertools functools abc dataclasses unittest pytest asyncio contextlib io math random hashlib uuid copy enum time threading subprocess argparse inspect traceback warnings weakref signal builtins string struct types numbers operator"

if [ -z "$STAGED_PY" ]; then
    echo -e "  ${GREEN}вњ… No Python files staged${NC}"
else
    for FILE in $STAGED_PY; do
        IMPORTS=$(git show ":$FILE" 2>/dev/null | grep -E "^import |^from " | sed 's/import //' | sed 's/from //' | awk '{print $1}' | cut -d'.' -f1 | tr '[:upper:]' '[:lower:]' | tr -d ',.;' | sort -u)
        VERSION_FILE=$(git show ":$FILE" 2>/dev/null | grep -E "^[a-zA-Z0-9_-]+==[0-9]" | head -20 || true)

        for LIB in $IMPORTS; do
            # Skip stdlib
            echo "$STDLIB" | grep -qw "$LIB" && continue

            # Get version if available
            VER=$(echo "$VERSION_FILE" | grep -i "^${LIB}==" | cut -d'=' -f3 || echo "")

            # Run CVE check script
            if [ -f "$SCRIPT_DIR/cve-check.py" ]; then
                CVE_OUTPUT=$(python3 "$SCRIPT_DIR/cve-check.py" --library "$LIB" --version "$VER" 2>&1)
                CVE_EXIT=$?

                case $CVE_EXIT in
                    0)  # Tier 1 or Tier 2 auto-approved
                        echo -e "  ${GREEN}вњ… $LIB вЂ” auto-approved${NC}"
                        ;;
                    1)  # Hard block вЂ” critical CVE
                        echo -e "  ${RED}вќЊ HARD BLOCK: $LIB${NC}"
                        echo "$CVE_OUTPUT" | sed 's/^/     /'
                        ((VIOLATIONS++))
                        ;;
                    2)  # Approval flow вЂ” moderate CVE or API inconclusive
                        echo -e "  ${YELLOW}вљ пёЏ  APPROVAL REQUIRED: $LIB${NC}"
                        echo "$CVE_OUTPUT" | sed 's/^/     /'
                        ((VIOLATIONS++))  # Block commit until approved
                        ;;
                    3)  # Clean but unknown вЂ” approval flow
                        echo -e "  ${CYAN}рџ“‹ APPROVAL FLOW: $LIB (clean but not whitelisted)${NC}"
                        echo "$CVE_OUTPUT" | sed 's/^/     /'
                        ((WARNINGS++))  # Warn only вЂ” don't block
                        ;;
                esac
            else
                # Fallback if script missing
                echo -e "  ${YELLOW}вљ пёЏ  CVE script missing вЂ” approval flow for: $LIB${NC}"
                ((WARNINGS++))
            fi
        done
    done
fi
echo ""

# =============================================================================
# CHECK 4 вЂ” Style violations
# =============================================================================

echo -e "${BLUE}[4/5] Style check...${NC}"

STAGED_PY_ONLY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$')

if [ -z "$STAGED_PY_ONLY" ]; then
    echo -e "  ${GREEN}вњ… No Python files staged${NC}"
else
    for FILE in $STAGED_PY_ONLY; do
        CONTENT=$(git show ":$FILE" 2>/dev/null)
        LINE_COUNT=$(echo "$CONTENT" | wc -l | tr -d ' ')

        # Line count
        if [ "$LINE_COUNT" -gt 150 ]; then
            echo -e "  ${RED}вќЊ $FILE: $LINE_COUNT lines (max 150)${NC}"
            ((VIOLATIONS++))
        fi

        # Skip print() check for CLI scripts вЂ” they legitimately use print for output
        if echo "$FILE" | grep -qE "\.claude/scripts/|scripts/.*\.py$"; then
          continue
        fi

        # print() statements
        PRINT_LINES=$(echo "$CONTENT" | grep -n "^\s*print(" | grep -v "#" || true)
        if [ -n "$PRINT_LINES" ]; then
            echo -e "  ${RED}вќЊ $FILE: print() found вЂ” use logging${NC}"
            ((VIOLATIONS++))
        fi

        # Type hints
        UNTYPED=$(echo "$CONTENT" | grep -n "^def \|^    def " | grep -v "->")
        if [ -n "$UNTYPED" ]; then
            echo -e "  ${YELLOW}вљ пёЏ  $FILE: functions missing return type hints${NC}"
            ((WARNINGS++))
        fi

        # Docstrings
        MISSING_DOCS=$(echo "$CONTENT" | python3 -c "
import sys, ast
try:
    tree = ast.parse(sys.stdin.read())
    missing = []
    for node in ast.walk(tree):
        if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):
            if not (node.body and isinstance(node.body[0], ast.Expr) and isinstance(node.body[0].value, ast.Constant)):
                missing.append(f'  line {node.lineno}: {node.name}()')
    print('\n'.join(missing))
except: pass
" 2>/dev/null || true)
        if [ -n "$MISSING_DOCS" ]; then
            echo -e "  ${YELLOW}вљ пёЏ  $FILE: missing docstrings:${NC}"
            echo "$MISSING_DOCS"
            ((WARNINGS++))
        fi
    done

    [ "$VIOLATIONS" -eq 0 ] && echo -e "  ${GREEN}вњ… No hard style violations${NC}"
    [ "$WARNINGS" -gt 0 ]   && echo -e "  ${YELLOW}вљ пёЏ  $WARNINGS warning(s) вЂ” fix before PR${NC}"
fi
echo ""

# =============================================================================
# CHECK 5 вЂ” Guard: deletions without flag
# =============================================================================

echo -e "${BLUE}[5/5] Guard check...${NC}"

DELETED_FILES=$(git diff --cached --name-only --diff-filter=D)
if [ -n "$DELETED_FILES" ]; then
    COMMIT_MSG=$(git log --format=%B -n 1 HEAD 2>/dev/null || echo "")
    if echo "$COMMIT_MSG" | grep -q "GUARD:ALLOW-DELETE"; then
        echo -e "  ${YELLOW}вљ пёЏ  Deletion flagged for approval flow: $DELETED_FILES${NC}"
        ((WARNINGS++))
    else
        echo -e "  ${RED}вќЊ HARD BLOCK: File deletion without [GUARD:ALLOW-DELETE] flag${NC}"
        echo -e "     Files: $DELETED_FILES"
        echo -e "     Add [GUARD:ALLOW-DELETE] to commit message to start approval flow"
        ((VIOLATIONS++))
    fi
else
    echo -e "  ${GREEN}вњ… No deletions detected${NC}"
fi
echo ""

# =============================================================================
# RESULT
# =============================================================================

echo -e "${BOLD}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${NC}"

if [ "$VIOLATIONS" -gt 0 ]; then
    echo -e "${BOLD}  вќЊ COMMIT BLOCKED вЂ” $VIOLATIONS violation(s)${NC}"
    echo -e "${BOLD}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${NC}"
    echo ""
    echo -e "  Fix violations above then commit again."
    echo -e "  Library approvals в†’ email sent to Prism7 automatically."
    echo ""
    exit 1
else
    echo -e "${BOLD}  вњ… CLEARED вЂ” Commit allowed${NC}"
    [ "$WARNINGS" -gt 0 ] && echo -e "  ${YELLOW}вљ пёЏ  $WARNINGS warning(s) вЂ” fix before PR/merge${NC}"
    echo -e "${BOLD}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${NC}"
    echo ""
    exit 0
fi

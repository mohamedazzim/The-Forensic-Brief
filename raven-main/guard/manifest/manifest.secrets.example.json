{
  "_warning": "NEVER commit this file. Add manifest.secrets.json to .gitignore immediately.",
  "_source": "Get this file from your architect via secure channel (1Password / AWS Secrets Manager / Azure Key Vault)",
  "approvals": {
    "shared_inbox": "prism7-yourproject@yourcompany.com",
    "approvers": [
      "lead-architect@yourcompany.com",
      "cto@yourcompany.com"
    ],
    "escalation": "cto@yourcompany.com",
    "webhook_url": "https://hooks.yourcompany.com/raven",
    "github_token": "env:GITHUB_TOKEN"
  },
  "notifications": {
    "token_warnings": {
      "75": [
        "dev",
        "team-lead"
      ],
      "90": [
        "dev",
        "team-lead",
        "shared-inbox"
      ],
      "95": [
        "dev",
        "team-lead",
        "shared-inbox"
      ],
      "overflow": "approval-flow"
    },
    "guard_alerts": {
      "p1": [
        "escalation",
        "shared-inbox"
      ],
      "p2": [
        "team-lead",
        "shared-inbox"
      ],
      "p3": [
        "shared-inbox"
      ]
    }
  },
  "smtp": {
    "host": "env:SMTP_HOST",
    "port": 587,
    "user": "env:SMTP_USER",
    "password": "env:SMTP_PASSWORD",
    "from": "raven@yourcompany.com"
  },
  "aws": {
    "sns_topic_arn": "env:SNS_TOPIC_ARN",
    "region": "us-east-1"
  },
  "guard": {
    "_note": "Guard-specific config. All optional \u2014 silent if not set.",
    "pagerduty_key": "YOUR_PAGERDUTY_ROUTING_KEY",
    "webhook_url": "https://your-prism7/guard/ingest",
    "weekly_digest": true,
    "_pagerduty_note": "P1 incidents only. Get key from PagerDuty \u2192 Services \u2192 Integrations"
  },
  "audit": {
    "_note": "Same S3 bucket as Core. Guard uses prefix: raven-guard/",
    "s3_bucket": "your-enterprise-audit-bucket",
    "s3_region": "us-east-1",
    "encryption_key": "same key as Core audit.encryption_key",
    "local_fallback": false
  }
}
{
  "hooks": {

    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type":    "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/.claude/scripts/tool-guard.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type":    "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/.claude/scripts/schema-guard.py\""
          }
        ]
      }
    ],

    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type":    "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/.claude/scripts/cve-prompt-guard.py\" 2>/dev/null || true",
            "async":   true
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type":    "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath // \"\"' | { read -r f; [ -n \"$f\" ] && python3 \"${CLAUDE_PROJECT_DIR:-.}/.claude/scripts/secret-scan.py\" --file \"$f\"; } 2>/dev/null || true",
            "async":   true
          },
          {
            "type":    "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/.claude/scripts/db-guard.py\"",
            "async":   true
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type":    "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/.claude/scripts/audit-log.py\"",
            "async":   true
          }
        ]
      }
    ],

    "PreCompact": [
      {
        "hooks": [
          {
            "type":    "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/.claude/scripts/token-guard.py\""
          }
        ]
      }
    ],

    "Notification": [
      {
        "hooks": [
          {
            "type":    "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/.claude/scripts/token-guard.py\"",
            "async":   true
          }
        ]
      }
    ],

    "Stop": [
      {
        "hooks": [
          {
            "type":    "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/.claude/scripts/audit-log.py\"",
            "async":   true
          },
          {
            "type":    "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/.claude/scripts/session-gate.py\" 2>/dev/null || true",
            "async":   true
          }
        ]
      }
    ],

    "SessionStart": [
      {
        "hooks": [
          {
            "type":    "command",
            "command": "python3 -c \"import json,pathlib,sys\nm=pathlib.Path('.raven/manifest.json')\nif m.exists():\n    try:\n        d=json.loads(m.read_text())\n        print(json.dumps({'additionalContext':f\\\"Raven v{d.get('raven_version',d.get('standards','3.0'))} active. Project: {d.get('project','unknown')}. Mode: {d.get('mode','team')}.\\\"}))  \n    except: pass\nelse:\n    print(json.dumps({'additionalContext':'RAVEN: manifest.json not found — project not initialised. Ask user if they want to run raven-init.'}))\" 2>/dev/null || true"
          }
        ]
      }
    ]

  }
}

#!/bin/bash

# =============================================================================
# Raven — Pre-commit Hook v3.0
# Three-tier library approval + CVE check (PyPI Safety + GPT-5.4-Cyber)
# =============================================================================

export RAVEN_COMMIT=1

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

VIOLATIONS=0
WARNINGS=0
PROJECT_ROOT=$(git rev-parse --show-toplevel)
MANIFEST="$PROJECT_ROOT/.raven/manifest.json"
SCRIPT_DIR="$PROJECT_ROOT/.claude/scripts"

echo ""
echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BOLD}  Raven Pre-commit v3.0${NC}"
echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# =============================================================================
# FRAMEWORK REPO DETECTION
# A framework repo has no app manifest of its own, so the manifest check (CHECK 1)
# is skipped. ALL other guards — publisher, secrets, CVE, style, deletions,
# DB-guard, and truth-guard — STILL RUN. The framework repo ships to every
# customer; it must hold itself to the same bar (or higher).
# =============================================================================
FRAMEWORK_REPO=0
if [ -f ".raven-framework" ]; then
    FRAMEWORK_REPO=1
    echo -e "${GREEN}✅ Framework repo — manifest check skipped; all other guards active${NC}"
    echo ""
fi

# =============================================================================
# CHECK 0 — Publisher prohibition: framework dirs must never be committed
# =============================================================================

echo -e "${BLUE}[0/5] Publisher check...${NC}"

FRAMEWORK_BLOCKED=0
for DIR in raven raven-guard .raven-framework .raven-guard; do
    # Check if staged
    if git diff --cached --name-only | grep -q "^$DIR/"; then
        echo ""
        echo -e "${RED}╔══════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${RED}║  PUBLISHER PROHIBITION — COMMIT BLOCKED                      ║${NC}"
        echo -e "${RED}╠══════════════════════════════════════════════════════════════╣${NC}"
        echo -e "${RED}║                                                               ║${NC}"
        echo -e "${RED}║  The Raven framework directory has been detected in           ║${NC}"
        echo -e "${RED}║  your staged files:  $DIR/$(printf '%*s' $((33-${#DIR})) '')║${NC}"
        echo -e "${RED}║                                                               ║${NC}"
        echo -e "${RED}║  The publisher (Giggso) prohibits committing the Raven        ║${NC}"
        echo -e "${RED}║  framework into project repositories. It must live outside   ║${NC}"
        echo -e "${RED}║  your project and never be tracked by your project's git.    ║${NC}"
        echo -e "${RED}║                                                               ║${NC}"
        echo -e "${RED}║  Fix:                                                        ║${NC}"
        echo -e "${RED}║  git rm -r --cached $DIR/$(printf '%*s' $((38-${#DIR})) '')║${NC}"
        echo -e "${RED}║  echo \"$DIR/\" >> .gitignore$(printf '%*s' $((36-${#DIR})) '')║${NC}"
        echo -e "${RED}║                                                               ║${NC}"
        echo -e "${RED}║  github.com/giggsoinc/raven                                  ║${NC}"
        echo -e "${RED}╚══════════════════════════════════════════════════════════════╝${NC}"
        echo ""
        FRAMEWORK_BLOCKED=1
    fi

    # Check if already tracked in repo (not just staged)
    if git ls-files --error-unmatch "$DIR/" &>/dev/null 2>&1; then
        echo -e "  ${RED}❌ PUBLISHER PROHIBITION: $DIR/ is tracked in git.${NC}"
        echo -e "     Run: git rm -r --cached $DIR/ && echo \"$DIR/\" >> .gitignore"
        FRAMEWORK_BLOCKED=1
    fi
done

[ "$FRAMEWORK_BLOCKED" -eq 1 ] && exit 1
echo -e "  ${GREEN}✅ Framework dirs not tracked${NC}"
echo ""

# =============================================================================
# CHECK 1 — Manifest (always hard block if missing)
# =============================================================================

echo -e "${BLUE}[1/5] Manifest check...${NC}"
if [ "$FRAMEWORK_REPO" -eq 1 ]; then
    echo -e "  ${GREEN}✅ Framework repo — no app manifest required${NC}"
else
    if [ ! -f "$MANIFEST" ]; then
        echo -e "  ${RED}❌ HARD BLOCK: manifest.json missing.${NC}"
        exit 1
    fi
    if ! python3 -c "import json; json.load(open('$MANIFEST'))" 2>/dev/null; then
        echo -e "  ${RED}❌ HARD BLOCK: manifest.json invalid JSON.${NC}"
        exit 1
    fi
    echo -e "  ${GREEN}✅ Manifest valid${NC}"
fi
echo ""

# =============================================================================
# CHECK 2 — Secrets never committed
# =============================================================================

echo -e "${BLUE}[2/5] Secrets check...${NC}"

STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM)

if echo "$STAGED_ALL" | grep -q "manifest.secrets.json"; then
    echo -e "  ${RED}❌ HARD BLOCK: manifest.secrets.json staged.${NC}"
    echo -e "     Run: git reset HEAD .raven/manifest.secrets.json"
    ((VIOLATIONS++))
fi

for FILE in $STAGED_ALL; do
    if git show ":$FILE" 2>/dev/null | grep -qE "(api_key|secret_key|password|AWS_SECRET|OPENAI_API_KEY|private_key)\s*=\s*['\"][^'\"]{8,}['\"]"; then
        echo -e "  ${RED}❌ HARD BLOCK: Possible secret in $FILE${NC}"
        ((VIOLATIONS++))
    fi
done

[ "$VIOLATIONS" -eq 0 ] && echo -e "  ${GREEN}✅ No secrets detected${NC}"
echo ""

# =============================================================================
# CHECK 3 — Library CVE check (three-tier system)
# =============================================================================

echo -e "${BLUE}[3/5] Library CVE check (three-tier)...${NC}"
echo ""

STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$|requirements.*\.txt$|pyproject\.toml$|setup\.py$')

# Stdlib — never flag
STDLIB="os sys json logging typing datetime pathlib re collections itertools functools abc dataclasses unittest pytest asyncio contextlib io math random hashlib uuid copy enum time threading subprocess argparse inspect traceback warnings weakref signal builtins string struct types numbers operator"

if [ -z "$STAGED_PY" ]; then
    echo -e "  ${GREEN}✅ No Python files staged${NC}"
else
    for FILE in $STAGED_PY; do
        IMPORTS=$(git show ":$FILE" 2>/dev/null | grep -E "^import |^from " | sed 's/import //' | sed 's/from //' | awk '{print $1}' | cut -d'.' -f1 | tr '[:upper:]' '[:lower:]' | tr -d ',.;' | sort -u)
        VERSION_FILE=$(git show ":$FILE" 2>/dev/null | grep -E "^[a-zA-Z0-9_-]+==[0-9]" | head -20 || true)

        for LIB in $IMPORTS; do
            # Skip stdlib
            echo "$STDLIB" | grep -qw "$LIB" && continue

            # Get version if available
            VER=$(echo "$VERSION_FILE" | grep -i "^${LIB}==" | cut -d'=' -f3 || echo "")

            # Run CVE check script
            if [ -f "$SCRIPT_DIR/cve-check.py" ]; then
                CVE_OUTPUT=$(python3 "$SCRIPT_DIR/cve-check.py" --library "$LIB" --version "$VER" 2>&1)
                CVE_EXIT=$?

                case $CVE_EXIT in
                    0)  # Tier 1 or Tier 2 auto-approved
                        echo -e "  ${GREEN}✅ $LIB — auto-approved${NC}"
                        ;;
                    1)  # Hard block — critical CVE
                        echo -e "  ${RED}❌ HARD BLOCK: $LIB${NC}"
                        echo "$CVE_OUTPUT" | sed 's/^/     /'
                        ((VIOLATIONS++))
                        ;;
                    2)  # Approval flow — moderate CVE or API inconclusive
                        echo -e "  ${YELLOW}⚠️  APPROVAL REQUIRED: $LIB${NC}"
                        echo "$CVE_OUTPUT" | sed 's/^/     /'
                        ((VIOLATIONS++))  # Block commit until approved
                        ;;
                    3)  # Clean but unknown — approval flow
                        echo -e "  ${CYAN}📋 APPROVAL FLOW: $LIB (clean but not whitelisted)${NC}"
                        echo "$CVE_OUTPUT" | sed 's/^/     /'
                        ((WARNINGS++))  # Warn only — don't block
                        ;;
                esac
            else
                # Fallback if script missing
                echo -e "  ${YELLOW}⚠️  CVE script missing — approval flow for: $LIB${NC}"
                ((WARNINGS++))
            fi
        done
    done
fi
echo ""

# =============================================================================
# CHECK 4 — Style violations
# =============================================================================

echo -e "${BLUE}[4/5] Style check...${NC}"

STAGED_PY_ONLY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$')

if [ -z "$STAGED_PY_ONLY" ]; then
    echo -e "  ${GREEN}✅ No Python files staged${NC}"
else
    for FILE in $STAGED_PY_ONLY; do
        CONTENT=$(git show ":$FILE" 2>/dev/null)
        LINE_COUNT=$(echo "$CONTENT" | wc -l | tr -d ' ')

        # Skip all style checks for Raven framework files — not project source code.
        # Hook/guard scripts legitimately use print() (stdout is the hook protocol)
        # and carry detailed help-text, so app-code rules (150 lines, no-print) don't apply.
        if echo "$FILE" | grep -qE "^(\.claude/(scripts|skills|agents)|raven-core|scripts|core/(scripts|hooks))/"; then
          continue
        fi

        # Line count
        if [ "$LINE_COUNT" -gt 150 ]; then
            echo -e "  ${RED}❌ $FILE: $LINE_COUNT lines (max 150)${NC}"
            ((VIOLATIONS++))
        fi

        # Skip print() check for CLI scripts — they legitimately use print for output
        if echo "$FILE" | grep -qE "scripts/.*\.py$"; then
          continue
        fi

        # print() statements
        PRINT_LINES=$(echo "$CONTENT" | grep -n "^\s*print(" | grep -v "#" || true)
        if [ -n "$PRINT_LINES" ]; then
            echo -e "  ${RED}❌ $FILE: print() found — use logging${NC}"
            ((VIOLATIONS++))
        fi

        # Type hints
        UNTYPED=$(echo "$CONTENT" | grep -n "^def \|^    def " | grep -v "->")
        if [ -n "$UNTYPED" ]; then
            echo -e "  ${YELLOW}⚠️  $FILE: functions missing return type hints${NC}"
            ((WARNINGS++))
        fi

        # Docstrings
        MISSING_DOCS=$(echo "$CONTENT" | python3 -c "
import sys, ast
try:
    tree = ast.parse(sys.stdin.read())
    missing = []
    for node in ast.walk(tree):
        if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):
            if not (node.body and isinstance(node.body[0], ast.Expr) and isinstance(node.body[0].value, ast.Constant)):
                missing.append(f'  line {node.lineno}: {node.name}()')
    print('\n'.join(missing))
except: pass
" 2>/dev/null || true)
        if [ -n "$MISSING_DOCS" ]; then
            echo -e "  ${YELLOW}⚠️  $FILE: missing docstrings:${NC}"
            echo "$MISSING_DOCS"
            ((WARNINGS++))
        fi
    done

    [ "$VIOLATIONS" -eq 0 ] && echo -e "  ${GREEN}✅ No hard style violations${NC}"
    [ "$WARNINGS" -gt 0 ]   && echo -e "  ${YELLOW}⚠️  $WARNINGS warning(s) — fix before PR${NC}"
fi
echo ""

# =============================================================================
# CHECK 5 — Guard: deletions without flag + raven-core protection
# =============================================================================

echo -e "${BLUE}[5/5] Guard check...${NC}"

DELETED_FILES=$(git diff --cached --name-only --diff-filter=D)

# Hard block: raven-core/*.py deletions are NEVER allowed — not even with GUARD:ALLOW-DELETE
# raven-core is the single source of truth. Deleting from here breaks all symlinks.
RAVEN_CORE_DELETED=$(echo "$DELETED_FILES" | grep "^raven-core/.*\.py$" || true)
if [ -n "$RAVEN_CORE_DELETED" ]; then
    echo ""
    echo -e "  ${RED}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "  ${RED}║  ⛔ HARD BLOCK — raven-core DELETION FORBIDDEN               ║${NC}"
    echo -e "  ${RED}╠══════════════════════════════════════════════════════════════╣${NC}"
    echo -e "  ${RED}║                                                               ║${NC}"
    echo -e "  ${RED}║  raven-core/ is the ONLY real copy of these engine scripts.  ║${NC}"
    echo -e "  ${RED}║  All other locations are symlinks pointing here.              ║${NC}"
    echo -e "  ${RED}║  Deleting from raven-core/ silently breaks ALL of them.      ║${NC}"
    echo -e "  ${RED}║                                                               ║${NC}"
    echo -e "  ${RED}║  Staged for deletion:                                         ║${NC}"
    echo "$RAVEN_CORE_DELETED" | while read -r F; do
    echo -e "  ${RED}║    ❌ $F $(printf '%*s' $((48-${#F})) '')║${NC}"
    done
    echo -e "  ${RED}║                                                               ║${NC}"
    echo -e "  ${RED}║  This block CANNOT be overridden with [GUARD:ALLOW-DELETE].  ║${NC}"
    echo -e "  ${RED}║  To replace a script: update it in raven-core/, never delete.║${NC}"
    echo -e "  ${RED}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    exit 1
fi

# All other deletions require [GUARD:ALLOW-DELETE] in commit message
NON_CORE_DELETED=$(echo "$DELETED_FILES" | grep -v "^raven-core/" || true)
if [ -n "$NON_CORE_DELETED" ]; then
    # Read the commit message from every source a pre-commit hook can see.
    # NOTE: `git commit -m MSG` writes COMMIT_EDITMSG only AFTER pre-commit runs,
    # so the file alone is unreliable. The env var is the dependable override.
    COMMIT_MSG=$(cat "$PROJECT_ROOT/.git/COMMIT_EDITMSG" 2>/dev/null || echo "")
    if [ "${RAVEN_ALLOW_DELETE:-0}" = "1" ] || echo "$COMMIT_MSG" | grep -q "GUARD:ALLOW-DELETE"; then
        echo -e "  ${YELLOW}⚠️  Deletion flagged for approval flow:${NC}"
        echo "$NON_CORE_DELETED" | sed 's/^/     /'
        ((WARNINGS++))
    else
        echo -e "  ${RED}❌ HARD BLOCK: File deletion without [GUARD:ALLOW-DELETE] flag${NC}"
        echo -e "     Files:"
        echo "$NON_CORE_DELETED" | sed 's/^/       /'
        echo -e "     To allow this deletion, EITHER:"
        echo -e "       • RAVEN_ALLOW_DELETE=1 git commit -m \"... [GUARD:ALLOW-DELETE]\"   (reliable)"
        echo -e "       • or pre-write the message: printf '...[GUARD:ALLOW-DELETE]' > .git/COMMIT_EDITMSG"
        ((VIOLATIONS++))
    fi
else
    echo -e "  ${GREEN}✅ No deletions detected${NC}"
fi
echo ""

# =============================================================================
# CHECK 6 — DB Guard: No inline SQL in non-SQL source files
# =============================================================================

echo -e "${BLUE}[6/6] DB Guard — SQL discipline check...${NC}"

SQL_VIOLATIONS=0
APP_EXTENSIONS="py java go cs ts js rb php"
SQL_PATTERN='(SELECT[[:space:]]+.+[[:space:]]+FROM|INSERT[[:space:]]+INTO|UPDATE[[:space:]]+.+[[:space:]]+SET|DELETE[[:space:]]+FROM|CREATE[[:space:]]+TABLE|ALTER[[:space:]]+TABLE|DROP[[:space:]]+TABLE|cursor\.execute|db\.query|\.raw\()'

STAGED_APP=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(py|java|go|cs|ts|js|rb|php)$' || true)

if [ -z "$STAGED_APP" ]; then
    echo -e "  ${GREEN}✅ No app source files staged${NC}"
else
    for FILE in $STAGED_APP; do
        CONTENT=$(git show ":$FILE" 2>/dev/null)
        MATCHES=$(echo "$CONTENT" | grep -nE "$SQL_PATTERN" | grep -v "^\s*#\|^\s*//" | head -5 || true)
        if [ -n "$MATCHES" ]; then
            echo -e "  ${RED}❌ HARD BLOCK: Inline SQL detected in $FILE${NC}"
            echo "$MATCHES" | while read -r LINE; do
                echo -e "     ${RED}→ $LINE${NC}"
            done
            echo -e "     ${YELLOW}Extract SQL to queries/*.sql and load via file reader${NC}"
            ((VIOLATIONS++))
            SQL_VIOLATIONS=1
        fi
    done
    [ "$SQL_VIOLATIONS" -eq 0 ] && echo -e "  ${GREEN}✅ No inline SQL found in source files${NC}"
fi
echo ""

# =============================================================================
# CHECK 7 — Truth Guard: no unverified marketing claims in docs (T1.5)
# Enforces the realstory truth-policy: a claim ships only if it's verifiably true.
# =============================================================================

echo -e "${BLUE}[7/7] Truth Guard — doc claim check...${NC}"
if [ -f "$SCRIPT_DIR/truth-guard.py" ]; then
    if ! python3 "$SCRIPT_DIR/truth-guard.py"; then
        ((VIOLATIONS++))
    fi
else
    echo -e "  ${GREEN}✅ truth-guard not installed in this repo — skipping${NC}"
fi
echo ""

# =============================================================================
# RESULT
# =============================================================================

echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# =============================================================================
# NOTIFY — fire SMTP + Slack notification (fail-soft, never blocks)
# Tries scripts/notify.py (framework repo) then .claude/scripts/notify.py (installed plugin)
# =============================================================================
NOTIFY_SCRIPT=""
if [ -f "$PROJECT_ROOT/scripts/notify.py" ]; then
    NOTIFY_SCRIPT="$PROJECT_ROOT/scripts/notify.py"
elif [ -f "$PROJECT_ROOT/.claude/scripts/notify.py" ]; then
    NOTIFY_SCRIPT="$PROJECT_ROOT/.claude/scripts/notify.py"
fi

STAGED_FILES=$(git diff --cached --name-only | head -20 | tr '\n' ',' | sed 's/,$//')

echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

if [ "$VIOLATIONS" -gt 0 ]; then
    echo -e "${BOLD}  ❌ COMMIT BLOCKED — $VIOLATIONS violation(s)${NC}"
    echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "  Fix violations above then commit again."
    echo -e "  Library approvals → email sent to Prism7 automatically."
    echo ""
    if [ -n "$NOTIFY_SCRIPT" ]; then
        python3 "$NOTIFY_SCRIPT" --event=block \
            --detail="$VIOLATIONS violation(s) blocked commit" \
            --files="$STAGED_FILES" 2>/dev/null || true
    fi
    exit 1
else
    echo -e "${BOLD}  ✅ CLEARED — Commit allowed${NC}"
    [ "$WARNINGS" -gt 0 ] && echo -e "  ${YELLOW}⚠️  $WARNINGS warning(s) — fix before PR/merge${NC}"
    echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    if [ -n "$NOTIFY_SCRIPT" ]; then
        python3 "$NOTIFY_SCRIPT" --event=commit \
            --detail="Pre-commit gate passed ($WARNINGS warning(s))" \
            --files="$STAGED_FILES" 2>/dev/null || true
    fi
    exit 0
fi

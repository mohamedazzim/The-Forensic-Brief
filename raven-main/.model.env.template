# Raven — Model Tier Routing (OSS)
# Copy to .raven/.model.env (or project root) — raven-init does this automatically.
# Routes each prompt to the cheapest adequate model.

# ── Dynamic Routing Configuration ────────────────────────────────────────────
# Raven classifies queries at UserPromptSubmit time into tiers:
#   SIMPLE   (0-2 points) — Single-file edits, "fix typo", "what does X return"
#   MEDIUM   (3-5 points) — Tests, debugging, doc generation (default)
#   COMPLEX  (6+ points)  — Architecture, security, multi-file reasoning
#   LOCAL_ONLY (forced)   — When secrets detected in context

[routing]
LOCAL_ONLY = ollama/dolphin-mistral:latest
SIMPLE     = anthropic/claude-haiku-4-5
MEDIUM     = anthropic/claude-sonnet-4-6
COMPLEX    = anthropic/claude-opus-4-7

# ── Available Models ─────────────────────────────────────────────────────────

[anthropic]
available = auto
source    = cloud
models    = claude-haiku-4-5, claude-sonnet-4-6, claude-opus-4-7
tier.claude-haiku-4-5  = paid_low      # ~$0.25/1M in,  $1.25/1M out
tier.claude-sonnet-4-6 = paid_mid      # ~$3/1M in,     $15/1M out
tier.claude-opus-4-7   = paid_high     # ~$15/1M in,    $75/1M out

[ollama]
available = auto
source    = local
models    = dolphin-mistral:latest, deepseek-r1:8b, gemma3:4b, qwen3:8b
tier.dolphin-mistral:latest = free
tier.deepseek-r1:8b         = free
tier.gemma3:4b              = free
tier.qwen3:8b               = free

# ── Cost-saving notes ────────────────────────────────────────────────────────
# • ~70% of prompts classify SIMPLE/MEDIUM → Haiku/Sonnet, not Opus.
# • Opus only fires on architecture, security audits, multi-file refactors.
# • LOCAL_ONLY routes to Ollama when secrets present — never hits cloud.
# • To force a single model everywhere, point all tiers at the same model.
# • Local-only. No telemetry. No Hub. (For Hub-aware routing, see raven-enterprise.)
